        return c
    }

    // Render the page to a complete HTML document and accumulate
    // bindings for every OnClick handler in the tree. The opening
    // `<html>` carries a `data-theme="dark|light"` attribute so
    // baseline rules (and any user CSS that respects the same
    // attribute) can theme the document without depending on
    // `prefers-color-scheme` — useful since WebKitGTK doesn't
    // propagate the OS color scheme to the page.
    public string Render() {
        this.BindNames    = new List<string>()
        this.BindHandlers = new List<Closure>()
        this.Counter      = 0
        let theme: string = this.EffectiveTheme()
        var html: string = "<!DOCTYPE html><html data-theme=\"" + Html.Escape(theme) + "\"><head><meta charset=utf-8>"
        html = html + "<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
        html = html + "<title>" + Html.Escape(this.Title) + "</title>"
        if (this.UseBaseline) {
            html = html + "<style>" + Page.BaselineCss() + "</style>"
        }
        if (String_Length(this.StylesheetUrl) > 0) {
            html = html + "<link rel=\"stylesheet\" href=\"" + Html.Escape(this.StylesheetUrl) + "\">"
        }
        let nx: int = this.ExtraCss.Count()
        for i in 0..nx {
            html = html + "<link rel=\"stylesheet\" href=\"" + Html.Escape(this.ExtraCss.Get(i)) + "\">"
        }
        var bodyTag: string = "<body>"
        if (this.FillFlag) {
            bodyTag = "<body class=\"amc-fill\">"
        }
        html = html + "</head>" + bodyTag
        html = html + this.RenderElement(this.Body)
        html = html + "</body></html>"
        return html
    }

    // ── Partial updates (v0.0.5) ──────────────────────────
    //
    // PatchInner replaces the inner HTML of `#targetId` with a
    // freshly-rendered subtree, accumulating its event bindings
    // into the page's bind table and re-registering them on the
    // window. Use to refresh a single DataGrid row, swap a tab
    // panel body, or any other partial update — much cheaper than
    // re-applying the whole Page.
    //
    //   page.PatchInner(win, "grid-body", newRowsContainer)
    //
    // The counter is intentionally NOT reset, so handler names
    // stay unique across calls. The element passed in does NOT
    // include `#targetId` itself — only its children replace the
    // existing inner HTML.
    public void PatchInner(win: Window, targetId: string, element: Element) {
        let before: int = this.BindNames.Count()
        let html: string = this.RenderElement(element)
        let after: int = this.BindNames.Count()
        for i in before..after {
            win.Bind(this.BindNames.Get(i), this.BindHandlers.Get(i))
        }
        win.SetInnerHtml(targetId, html)
    }

    // AppendInner adds the rendered element as a new last child of
    // `#targetId` instead of replacing the existing children. Same
    // binding contract as PatchInner — typical use is appending a
    // new row to a ListView body.
    public void AppendInner(win: Window, targetId: string, element: Element) {
        let before: int = this.BindNames.Count()
        let html: string = this.RenderElement(element)
        let after: int = this.BindNames.Count()
        for i in before..after {
            win.Bind(this.BindNames.Get(i), this.BindHandlers.Get(i))
        }
        win.AppendHtml(targetId, html)
    }

    // HTML void elements — no closing tag, no children. Browsers
    // tolerate `</input>` but it parses as a stray end-tag error
    // and bloats the document; emit `<input ...>` for these.
    public static bool IsVoidTag(tag: string) {
        return tag == "input"
            || tag == "br"
            || tag == "hr"
            || tag == "img"
            || tag == "meta"
            || tag == "link"
    }

    // Walk one element. Recursive — children render inside.
    public string RenderElement(e: Element) {
        // Pseudo-tag for Element.Raw(html) — emit the raw payload
        // verbatim, no `<tag>` wrapping. See Element.Raw().
        if (e.Tag == "__raw__") {
            return e.Text
        }
        // Pseudo-tag for Element.MenuItem(label) — expand into
        // <details class=amc-menu><summary>label</summary>
        // <div class=amc-menu-popup>children</div></details>
        // so the user's AddChild(MenuOption/Separator) lands in
        // the popup automatically.
        if (e.Tag == "__menuitem__") {
            var m: string = "<details class=\"amc-menu\">"
            m = m + "<summary class=\"amc-menu-label\">" + Html.Escape(e.Text) + "</summary>"
            m = m + "<div class=\"amc-menu-popup\">"
            let nm: int = e.Children.Count()
            for i in 0..nm {
                m = m + this.RenderElement(e.Children.Get(i))
            }
            m = m + "</div></details>"
            return m
        }
        // Pseudo-tag for Element.SplitContainer — wraps the first
        // two children in <div class=amc-split-pane> sections
        // separated by a <div class=amc-split-divider>. Extra
        // children are ignored (use nested SplitContainers).
        if (e.Tag == "__splitcontainer__") {
            var orient: string = "row"
            var ratio:  string = "50"
            let nak: int = e.AttrKeys.Count()
            for ai in 0..nak {
                if (e.AttrKeys.Get(ai) == "data-orient") {
                    orient = e.AttrVals.Get(ai)
                }
                if (e.AttrKeys.Get(ai) == "data-ratio") {
                    ratio = e.AttrVals.Get(ai)
                }
            }
            var split: string = "<div class=\"amc-split amc-split-" + orient + "\" data-orient=\"" + orient + "\" data-ratio=\"" + ratio + "\">"
            let nsc: int = e.Children.Count()
            // Pane 1
            split = split + "<div class=\"amc-split-pane amc-split-pane-1\" style=\"flex:" + ratio + "\">"
            if (nsc >= 1) {
                split = split + this.RenderElement(e.Children.Get(0))
            }
            split = split + "</div>"
            // Divider
            split = split + "<div class=\"amc-split-divider\"></div>"
            // Pane 2
            let other: int = 100 - String_ToInt(ratio)
            split = split + "<div class=\"amc-split-pane amc-split-pane-2\" style=\"flex:" + String_FromInt(other) + "\">"
            if (nsc >= 2) {
                split = split + this.RenderElement(e.Children.Get(1))
            }
            split = split + "</div></div>"
            return split
        }
        var s: string = "<" + e.Tag
        let nk: int = e.AttrKeys.Count()
        for i in 0..nk {
            let k: string = e.AttrKeys.Get(i)
            let v: string = e.AttrVals.Get(i)
            s = s + " " + k + "=\"" + Html.Escape(v) + "\""
        }
        if (String_Length(e.StyleCss) > 0) {
            s = s + " style=\"" + Html.Escape(e.StyleCss) + "\""
        }
        // Event emission — one HTML `on<event>=` attribute per row in
        // the Element's event table. Each handler is bound under a
        // fresh `_amc_<n>` name via Window.Bind. Result routing
        // falls back from the per-event captured target to the
        // Element's default ResultTargetId, so both
        // `.OnResult(x).OnClick(h)` and `.OnClick(h).OnResult(x)`
        // work as expected.
        let ne: int = e.Events.Count()
        for i in 0..ne {
            this.Counter = this.Counter + 1
            let bname: string = "_amc_" + String_FromInt(this.Counter)
            this.BindNames.Add(bname)
            this.BindHandlers.Add(e.EventHandlers.Get(i))
            let call: string = "window." + bname + "(JSON.stringify(window.__amc_collect()))"
            var target: string = e.EventResults.Get(i)
            if (String_Length(target) == 0) {
                target = e.ResultTargetId
            }
            var expr: string = call
            if (String_Length(target) > 0) {
                let idLit: string = Html.Escape(Json.EncodeString(target))
                expr = "window.__amc_route(" + call + "," + idLit + ")"
            }
            s = s + " on" + e.Events.Get(i) + "=\"" + expr + "\""
        }
        s = s + ">"
        if (Page.IsVoidTag(e.Tag)) {
            return s
        }
        if (String_Length(e.Text) > 0) {
            s = s + Html.Escape(e.Text)
        }
        let nc: int = e.Children.Count()
        for i in 0..nc {
            s = s + this.RenderElement(e.Children.Get(i))
        }
        s = s + "</" + e.Tag + ">"
        return s
    }

    // Push the page into a window. Injects the form-collect bridge
    // (and the chrome-lockdown guard unless AllowBrowserDefaults()
    // was called), sets the HTML, then registers each OnClick
    // handler via Window.Bind.
    //
    // The form bridge (`window.__amc_collect`) walks every input/
    // select/textarea with a `name` attribute and returns a plain
    // object whose keys are the names and values are the field
    // values (booleans for checkboxes; selected `value` for radio
    // groups). Each OnClick onclick attribute stringifies that
    // object and passes it as the single argument to the bound
    // handler.
    //
    // The chrome guard blocks the webview's native context menu and
    // the reload hotkeys (F5, Ctrl+R, Cmd+R, plus the shifted hard-
    // reload variants). Reasons:
    //   - The page is loaded via SetHtml, not a URL — reloading
    //     ends up at about:blank and the app is stuck.
    //   - Most productive desktop apps (VS Code, Slack, Tauri
    //     defaults) hide the native browser chrome for the same
    //     reason.
    public void ApplyTo(win: Window) {
        var initJs: string = "window.__amc_collect=function(){var o={};document.querySelectorAll('input[name],select[name],textarea[name]').forEach(function(el){var n=el.getAttribute('name');if(el.type==='checkbox'){o[n]=el.checked;}else if(el.type==='radio'){if(el.checked){o[n]=el.value;}}else{o[n]=el.value;}});return o;};"
        // Result router for Element.OnResult(targetId). Awaits the
        // bound handler's promise, then writes the return value into
        // the target element. We pretty-print valid JSON for
        // readability and fall through to the raw string for plain-
        // text returns — so handlers that return `Json.EncodeString`
        // wrappers AND handlers that return free-form strings both
        // render usefully. The lookup is intentionally late-bound
        // (querySelector at click time, not render time) so targets
        // injected after Render still resolve.
        initJs = initJs + "window.__amc_route=function(p,id){Promise.resolve(p).then(function(r){var el=document.getElementById(id);if(!el)return;try{el.textContent=JSON.stringify(JSON.parse(r),null,2);}catch(e){el.textContent=r;}});};"
        // v0.0.8 — menu bridges. The MenuBar uses native <details>
        // for toggle; click anywhere outside an open menu closes it.
        // ContextMenu opens on right-click on .amc-ctx-target
        // elements and closes on outside click / Escape.
        initJs = initJs + "document.addEventListener('click',function(e){document.querySelectorAll('nav.amc-menubar>details.amc-menu[open]').forEach(function(d){if(!d.contains(e.target))d.open=false;});document.querySelectorAll('.amc-ctxmenu').forEach(function(m){if(m.style.display==='flex'&&!m.contains(e.target))m.style.display='none';});});"
        initJs = initJs + "document.addEventListener('contextmenu',function(e){var t=e.target;while(t&&!(t.classList&&t.classList.contains('amc-ctx-target'))){t=t.parentElement;}if(!t)return;var m=t.querySelector('.amc-ctxmenu');if(!m)return;e.preventDefault();m.style.display='flex';m.style.top=e.clientY+'px';m.style.left=e.clientX+'px';});"
        initJs = initJs + "document.addEventListener('keydown',function(e){if(e.key==='Escape'){document.querySelectorAll('nav.amc-menubar>details.amc-menu[open]').forEach(function(d){d.open=false;});document.querySelectorAll('.amc-ctxmenu').forEach(function(m){m.style.display='none';});}});"
        // v0.0.8 — SplitContainer drag. Pointer-down on a
        // divider starts a drag; pointer-move adjusts the two
        // panes' flex grow values according to the cursor's
        // position relative to the container's bounding rect.
        initJs = initJs + "document.addEventListener('pointerdown',function(e){if(!e.target.classList||!e.target.classList.contains('amc-split-divider'))return;var split=e.target.parentElement;var orient=split.getAttribute('data-orient')||'row';var p1=split.querySelector('.amc-split-pane-1');var p2=split.querySelector('.amc-split-pane-2');if(!p1||!p2)return;e.preventDefault();var rect=split.getBoundingClientRect();function update(ev){var pos,size;if(orient==='row'){pos=ev.clientX-rect.left;size=rect.width;}else{pos=ev.clientY-rect.top;size=rect.height;}var pct=Math.max(5,Math.min(95,Math.round(pos*100/size)));p1.style.flex=pct;p2.style.flex=(100-pct);}function up(){document.removeEventListener('pointermove',update);document.removeEventListener('pointerup',up);}document.addEventListener('pointermove',update);document.addEventListener('pointerup',up);});"
        // External link routing happens via the inline `onclick`
        // attribute emitted by Element.Link — direct, no global
        // event delegate (so no race with the webview's native
        // navigation handler, and no risk of double-firing when an
        // <a> already carries its own onclick).
        if (this.LockChrome) {
            initJs = initJs + "document.addEventListener('contextmenu',function(e){e.preventDefault();},true);"
            initJs = initJs + "document.addEventListener('keydown',function(e){var k=e.key;var m=e.ctrlKey||e.metaKey;if(k==='F5'){e.preventDefault();return;}if(m&&(k==='r'||k==='R')){e.preventDefault();return;}},true);"
        }
        win.Init(initJs)
        let html: string = this.Render()
        win.SetHtml(html)
        // Bind the link-opener handler. The closure parses the JSON-
        // stringified URL and forwards it to the C launcher. Defined
        // even if the page contains no <a> elements — cheap and lets
        // dynamically-injected links work too.
        //
        // We call the C primitive directly inside the lambda rather
        // than going through Page.OpenExternalUrl — amc's current
        // codegen for static-method calls inside a closure threads
        // the class name as a phantom `self` arg, causing a C
        // compile error. The `@c` block sidesteps that.
        win.Bind("_amc_openurl", (req: string) => {
            // webview/webview wraps every bind callback's argv as
            // a JSON array: e.g. `window.foo("a","b")` arrives as
            // `["a","b"]`. So `req` is `["url"]`, NOT just `url`.
            // We strip the brackets, then the inner string's quotes,
            // then un-escape the standard JSON sequences.
            var s: string = req
            let n0: int = String_Length(s)
            if (n0 >= 2 && String_StartsWith(s, "[")) {
                s = String_Substring(s, 1, n0 - 2)
            }
            let n1: int = String_Length(s)
            if (n1 >= 2 && String_StartsWith(s, "\"")) {
                s = String_Substring(s, 1, n1 - 2)
            }
            s = String_Replace(s, "\\/",  "/")
            s = String_Replace(s, "\\\"", "\"")
            s = String_Replace(s, "\\\\", "\\")
            Console.WriteLine("[ui-web] _amc_openurl -> " + s)
            var rc: int = 1
            @c {
                rc = (i64)Amalgame_UI_Web_OpenUrl(s);
            }
            Console.WriteLine("[ui-web] OpenUrl rc=" + String_FromInt(rc))
            if (rc == 0) { return "true" }
            return "false"
        })
        let n: int = this.BindNames.Count()
        for i in 0..n {
            win.Bind(this.BindNames.Get(i), this.BindHandlers.Get(i))
        }
    }
}

// ─── Form & Application (v0.0.7) ──────────────────────────
//
// WinForms-style entry point. `Form` is a value-holder that
// bundles title + size + body + lifecycle hooks; `Application.Run`
// expands it into `Window + Page + ApplyTo + Run + Destroy`.
//
// Idiomatic shape — one `Form` per top-level window:
//
//   class Program {
//       public static void Main() {
//           let f: Form = new Form("My App", 800, 600)
//           f.SetBody(Element.Stack()
//               .AddChild(Element.Heading("Welcome"))
//               .AddChild(Element.Button("Quit")
//                   .OnClick((req: string) => req)))
//           Application.Run(f)
//       }
//   }
//
// The Form is intentionally a plain value (not a base class to
// subclass) — AM's static dispatch makes virtual-method overrides
// in a parent class unreliable. Fluent setters keep the API
// composable; for richer lifecycle, attach a `Window.Bind` after
// `Application.Run` or set `OnLoad` to run code right after the
// page is rendered.

public class Form {
    public Title:     string
    public W:         int
    public H:         int
    public Body:      Element
    public Debug:     bool
    public OnLoadFn:  Closure
    public HasOnLoad: bool
    // Resolved theme override — passed through to Page.SetTheme.
    // "auto" (default) follows the OS.
    public ThemeMode: string

    public Form(title: string, w: int, h: int) {
        this.Title     = title
        this.W         = w
        this.H         = h
        this.Body      = Element.Stack()
        this.Debug     = false
        this.HasOnLoad = false
        this.ThemeMode = "auto"
    }

    public Form SetBody(e: Element) {
        this.Body = e
        return this
    }

    public Form SetDebug(d: bool) {
        this.Debug = d
        return this
    }

    public Form SetTheme(mode: string) {
        this.ThemeMode = mode
        return this
    }

    // Run a closure after the window's HTML is in place. The
    // closure's `req` argument is the JSON form snapshot at the
    // moment of dispatch — usually empty since no user input has
    // happened yet. Use this to bind extra `Window.Bind` handlers
    // not exposed declaratively in the Element tree.
    public Form OnLoad(handler: Closure) {
        this.OnLoadFn  = handler
        this.HasOnLoad = true
        return this
    }
}

public class Application {
    // Open the form's window, render its body, fire OnLoad, then
    // run the event loop until the user closes the window. Idiomatic
    // top-level call from Main(). Returns 0 on normal exit, non-zero
    // when the window couldn't be created.
    public static int Run(form: Form) {
        let win: Window = new Window(form.Title, form.W, form.H, form.Debug)
        if (!win.IsValid()) {
            return 1
        }
        let page: Page = Page.New()
            .SetTitle(form.Title)
            .SetTheme(form.ThemeMode)
            .SetBody(form.Body)
        page.ApplyTo(win)
        if (form.HasOnLoad) {
            // Use Window.Eval to fire a one-shot synthetic call that
            // dispatches the bound handler. The closure runs on the
            // webview's main thread, so any AppendInner / SetInnerHtml
            // inside it lands on the rendered page.
            win.Bind("_amc_form_onload", form.OnLoadFn)
            win.Eval("window._amc_form_onload('');")
        }
        win.Run()
        win.Destroy()
        return 0
    }
}
