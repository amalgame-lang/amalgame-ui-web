namespace Amalgame.UI.Web

@c {
    #include "Amalgame_UI_Web.h"
}

// ═══════════════════════════════════════════════════════════
//  facade.am — Webview binding (v0.0.1-dev)
// ═══════════════════════════════════════════════════════════
//
// Public surface (MVP):
//   - Window.New(title, w, h, debug)   creates an OS-native webview
//   - window.Navigate(url)             load a URL (http/https/file)
//   - window.SetHtml(html)             load HTML directly
//   - window.SetTitle(title)
//   - window.SetSize(w, h, hint)
//   - window.Init(js)                  inject JS before page load
//   - window.Eval(js)                  run JS now
//   - window.Run()                     block on event loop
//   - window.Terminate()               break out of Run
//   - window.Destroy()                 free the webview
//
// Backed by webview/webview (MIT) — rendering goes to WebView2 on
// Windows, WKWebView on macOS, WebKitGTK on Linux. App developers
// write Amalgame for the backend and HTML/CSS/JS for the UI.
//
// IPC (webview_bind callback into Amalgame) is deferred to v0.0.2.
// For v0.0.1, drive the JS side via Eval() and surface user
// actions back to Amalgame via a local HTTP server hosted from
// the app (or by polling a hidden DOM node via Eval roundtrips).

// ─── Size hints ────────────────────────────────────────────
//
// Mirror webview_hint_t exactly. Used by Window.SetSize.

public class WindowHint {
    public static int None()  { return 0 }   // user can resize freely
    public static int Min()   { return 1 }   // (w, h) is the minimum
    public static int Max()   { return 2 }   // (w, h) is the maximum
    public static int Fixed() { return 3 }   // (w, h) is locked
}

// ─── Tiny HTML / JSON escape helpers ──────────────────────
// (Declared before Window so Window methods that build JS
// payloads — SetInnerHtml, AppendHtml — can use Json.EncodeString
// without a forward-declaration trick.)

public class Html {
    // Minimal HTML escape — covers the attack surface for
    // user-supplied text content and attribute values. Order
    // matters: `&` first so we don't double-escape the entities
    // we're emitting.
    public static string Escape(s: string) {
        var r: string = s
        r = String_Replace(r, "&", "&amp;")
        r = String_Replace(r, "<", "&lt;")
        r = String_Replace(r, ">", "&gt;")
        r = String_Replace(r, "\"", "&quot;")
        return r
    }
}

public class Json {
    // JSON-encode a single string value — wraps in double quotes
    // and escapes `\` and `"`. Newlines / CR / tabs are escaped
    // too (Window.SetInnerHtml's payload becomes a JS string
    // literal, which forbids raw control chars). Non-ASCII UTF-8
    // passes through as-is — most JSON parsers accept it.
    //
    // For Bind handlers, wrap your free-form return strings with
    // this so the JS side receives a proper string value rather
    // than a parse error:
    //
    //     win.Bind("save", (req: string) => Json.EncodeString("ok"))
    public static string EncodeString(s: string) {
        var r: string = s
        r = String_Replace(r, "\\", "\\\\")
        r = String_Replace(r, "\"", "\\\"")
        r = String_Replace(r, "\r", "\\r")
        r = String_Replace(r, "\n", "\\n")
        r = String_Replace(r, "\t", "\\t")
        return "\"" + r + "\""
    }
}

// ─── Window ────────────────────────────────────────────────

public class Window {
    public Slot:  int     // -1 means "not created" / already destroyed
    public Title: string
    public Width: int
    public Height: int

    // Create a webview window. `debug` enables DevTools (Ctrl+Shift+I
    // on Windows/Linux; cmd+option+I on macOS once the right flag is
    // set). Returns a Window whose Slot is -1 if creation failed —
    // check IsValid() before using.
    public Window(title: string, w: int, h: int, debug: bool) {
        let s: int = 0
        @c {
            s = Amalgame_UI_Web_Create(debug ? 1 : 0);
        }
        this.Slot   = s
        this.Title  = title
        this.Width  = w
        this.Height = h
        if (s >= 0) {
            @c {
                Amalgame_UI_Web_SetTitle(s, title);
                Amalgame_UI_Web_SetSize(s, w, h, 0);
            }
        }
    }

    public bool   IsValid()   { return this.Slot >= 0 }
    public int    GetSlot()   { return this.Slot }
    public string GetTitle()  { return this.Title }
    public int    GetWidth()  { return this.Width }
    public int    GetHeight() { return this.Height }

    public void SetTitle(t: string) {
        this.Title = t
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_SetTitle(s, t);
        }
    }

    public void SetSize(w: int, h: int, hint: int) {
        this.Width  = w
        this.Height = h
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_SetSize(s, w, h, hint);
        }
    }

    // Load a URL. `http://`, `https://`, `file://` and `data:` schemes
    // all work. For local HTML packaged with the app, prefer
    // `file:///absolute/path/to/index.html` in v0.0.1 — custom
    // `am://` schemes land in v0.10+.
    public void Navigate(url: string) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Navigate(s, url);
        }
    }

    // Load an HTML string directly. Useful for static "about" pages
    // and unit tests. Note: relative paths in href/src are resolved
    // against `about:blank`, so prefer absolute URLs or inline
    // assets when going this route.
    public void SetHtml(html: string) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_SetHtml(s, html);
        }
    }

    // Inject JavaScript that runs *before every page load*. Use this
    // for bridges that must exist on `DOMContentLoaded` — e.g.
    // overriding `window.fetch` to route through Amalgame, or
    // declaring a `window.amalgame = { ... }` API surface.
    public void Init(js: string) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Init(s, js);
        }
    }

    // Run JavaScript in the current page. Fire-and-forget — the
    // result is not returned synchronously. Wire results back
    // through DOM mutations + Eval polling, or via the local
    // HTTP-bridge pattern, until v0.0.2 lands real bind callbacks.
    public void Eval(js: string) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Eval(s, js);
        }
    }

    // ── Partial DOM updates (v0.0.5) ──────────────────────
    //
    // SetInnerHtml replaces the inner HTML of `#elementId` without
    // re-rendering the whole page. Useful for DataGrid-style apps
    // that need to refresh just the rows, append a new row, swap
    // a panel, etc. Cheaper than ApplyTo every time and preserves
    // form-input state outside the patched region.
    //
    // The HTML is injected via element.innerHTML assignment, so
    // inline `on<event>=` attributes survive — Page.PatchInner
    // pairs this with new Window.Bind registrations so any
    // freshly-rendered OnClick handler stays wired.
    public void SetInnerHtml(elementId: string, html: string) {
        let idLit: string = Json.EncodeString(elementId)
        let htmlLit: string = Json.EncodeString(html)
        let js: string = "(function(){var el=document.getElementById(" + idLit + ");if(el){el.innerHTML=" + htmlLit + ";}})();"
        this.Eval(js)
    }

    // Append HTML as a new last-child of `#elementId`. Same
    // contract as SetInnerHtml — use Page.PatchInner for the
    // typed Element variant.
    public void AppendHtml(elementId: string, html: string) {
        let idLit: string = Json.EncodeString(elementId)
        let htmlLit: string = Json.EncodeString(html)
        let js: string = "(function(){var el=document.getElementById(" + idLit + ");if(el){el.insertAdjacentHTML('beforeend'," + htmlLit + ");}})();"
        this.Eval(js)
    }

    // Remove the element with the given id from the DOM. No-op if
    // missing. Useful for closing dialogs, dismissing rows, etc.
    public void RemoveElement(elementId: string) {
        let idLit: string = Json.EncodeString(elementId)
        let js: string = "(function(){var el=document.getElementById(" + idLit + ");if(el){el.remove();}})();"
        this.Eval(js)
    }

    // Block on the event loop until the window closes or
    // Terminate() is called. Always call this last from main().
    public void Run() {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Run(s);
        }
    }

    // Break out of Run from another thread / dispatch callback.
    // Rarely needed in v0.0.1 (no IPC) — useful when bind lands.
    public void Terminate() {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Terminate(s);
        }
    }

    // Free the webview and release its slot. Call after Run()
    // returns; further method calls become no-ops.
    public void Destroy() {
        let s: int = this.Slot
        if (s >= 0) {
            @c {
                Amalgame_UI_Web_Destroy(s);
            }
            this.Slot = -1
        }
    }

    // Register an Amalgame handler for `window.<name>(...)` calls
    // made from the JS side of the webview. The handler receives
    // the JSON-encoded JS argument list (e.g. `window.foo(1,"x")`
    // arrives as the string `[1,"x"]`) and MUST return valid JSON —
    // webview_return parses the result on the JS side. Examples:
    //
    //     win.Bind("echo",  (req: string) => req)             // echoes args back
    //     win.Bind("ping",  (req: string) => "\"pong\"")      // string  → "pong"
    //     win.Bind("count", (req: string) => "42")             // number  → 42
    //     win.Bind("ok",    (req: string) => "{\"ok\":true}") // object  → {ok:true}
    //
    // Returning raw text without proper JSON quoting will surface
    // as `Unhandled Promise Rejection: Error: Failed to parse
    // binding result as JSON` on the JS side. For free-form strings
    // with user content, escape via Amalgame.Formats.Json before
    // wrapping in quotes.
    //
    // The handler MUST be a typed-param lambda: the multi-param
    // form `(req: string) => …` tells amc to pass `req` as a
    // pointer rather than the legacy boxed i64. Single-arg bare
    // form `req => …` would type `req` as i64 and segfault on the
    // first character access.
    //
    // Implementation note: the lambda's AmalgameClosure* is stored
    // on the C side in a fixed-size registry (cap 64) keyed by
    // (slot, name). The C trampoline dispatches every JS call via
    // AmalgameClosure_call2(req, NULL) and forwards the returned
    // code_string back to JS through webview_return automatically.
    public void Bind(name: string, handler: Closure) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Bind(s, name, (void*)handler);
        }
    }

    // Drop a previously-registered binding. Idempotent.
    public void Unbind(name: string) {
        let s: int = this.Slot
        @c {
            Amalgame_UI_Web_Unbind(s, name);
        }
    }
}

// ═══════════════════════════════════════════════════════════
//  v0.0.3 — Higher-level HTML builder API
// ═══════════════════════════════════════════════════════════
//
// `Element` + `Page` let apps compose a webview UI in Amalgame
// without writing HTML strings by hand. Render() produces an HTML
// document; ApplyTo(window) pushes it into the webview and
// auto-registers every OnClick handler via Window.Bind.
//
// Use the raw Window.SetHtml / .Navigate path when you need full
// control (custom CSS framework, hand-written HTML, embedded
// templates, etc). The builder is sugar, not a wall.
//
// Example:
//
//     let page = Page.New()
//         .SetTitle("My App")
//         .SetBody(
//             Element.Stack()
//                 .AddChild(Element.Label("Hello, world"))
//                 .AddChild(Element.Button("Save")
//                     .OnClick((req: string) => "true"))
//         )
//     page.ApplyTo(win)
//     win.Run()

// ─── Tiny HTML / JSON escape helpers ──────────────────────

// ─── Dialog — modal message box (v0.0.6) ──────────────────
//
// Equivalent to WinForms' `MessageBox.Show`. Pops a native-styled
// modal over the current page with a heading, message, and a set
// of buttons. The user's choice flows back into Amalgame through
// a closure callback — handlers receive the button id as the
// `req` string ("ok", "cancel", "yes", "no", "close").
//
// Implementation: appends a <dialog id="amc-dialog"> with the
// requested buttons, binds `_amc_dialog_result` to forward the
// click, calls `dialog.showModal()` via Eval. The HTML <dialog>
// element handles the focus trap + Esc-to-close natively (Esc
// emits "cancel" through the bound callback).
//
// Single global slot — opening a new Dialog while one is visible
// replaces the previous one. Adequate for v0.0.6; future versions
// may stack via per-call ids.

public class Dialog {
    // Info dialog — single OK button. The handler fires with
    // "ok" when the user dismisses. Pass `null` (an empty
    // closure that returns "") if you don't need to react.
    public static void Info(win: Window, title: string, message: string, handler: Closure) {
        Dialog.Show(win, "info", title, message, "ok", handler)
    }

    // Warning dialog — single OK button with a warning accent.
    public static void Warning(win: Window, title: string, message: string, handler: Closure) {
        Dialog.Show(win, "warning", title, message, "ok", handler)
    }

    // Error dialog — single OK button with a destructive accent.
    public static void Error(win: Window, title: string, message: string, handler: Closure) {
        Dialog.Show(win, "error", title, message, "ok", handler)
    }

    // Confirm — OK / Cancel. Handler fires with "ok" or "cancel".
    public static void Confirm(win: Window, title: string, message: string, handler: Closure) {
        Dialog.Show(win, "info", title, message, "ok-cancel", handler)
    }

    // Yes / No / Cancel. Handler fires with "yes", "no", or "cancel".
    public static void YesNoCancel(win: Window, title: string, message: string, handler: Closure) {
        Dialog.Show(win, "info", title, message, "yes-no-cancel", handler)
    }

    // Open-file picker — equivalent to WinForms' OpenFileDialog.
    // Triggers the native OS file picker through a hidden
    // `<input type=file>`. The handler receives the JSON-stringified
    // file name (browser sandbox prevents exposing the full path).
    // `accept` is a comma-separated MIME / extension filter, e.g.
    // ".png,.jpg" or "image/*"; pass "" for no filter.
    //
    // The handler fires with the chosen filename, or "" if the user
    // cancelled (the change event also fires on cancel in some
    // engines — we filter empty selection on the JS side).
    //
    // Limitation: the file content is not exposed yet — only the
    // name. Use Window.Eval + FileReader on the JS side to read
    // the bytes; planned for a future release as an opt-in
    // Dialog.OpenFileContent that wires the FileReader bridge.
    public static void OpenFile(win: Window, accept: string, handler: Closure) {
        win.Bind("_amc_dialog_file", handler)
        let acceptLit: string = Json.EncodeString(accept)
        var js: string = "(function(){var i=document.createElement('input');i.type='file';i.style.display='none';"
        js = js + "var a=" + acceptLit + ";if(a)i.accept=a;"
        js = js + "i.onchange=function(){var f=i.files&&i.files[0];window._amc_dialog_file(f?f.name:'');document.body.removeChild(i);};"
        js = js + "i.oncancel=function(){window._amc_dialog_file('');document.body.removeChild(i);};"
        js = js + "document.body.appendChild(i);i.click();"
        js = js + "})()"
        win.Eval(js)
    }

    // Open-file picker that ALSO reads the file content. Same UX
    // as OpenFile but the handler receives a JSON-encoded object:
    //
    //   {"name": "report.txt", "content": "Hello, file..."}
    //
    // Content is read via FileReader.readAsText so binary files
    // come back as garbled strings — for binary use cases, pass
    // `binary=true` and the content is base64-encoded
    // (`readAsDataURL`'s suffix). `accept` filters as in OpenFile.
    //
    // On cancel, the handler receives `""` (empty string).
    public static void OpenFileContent(win: Window, accept: string, binary: bool, handler: Closure) {
        win.Bind("_amc_dialog_filecontent", handler)
        let acceptLit: string = Json.EncodeString(accept)
        var readerCall: string = "r.readAsText(f);"
        if (binary) {
            readerCall = "r.readAsDataURL(f);"
        }
        var js: string = "(function(){var i=document.createElement('input');i.type='file';i.style.display='none';"
        js = js + "var a=" + acceptLit + ";if(a)i.accept=a;"
        js = js + "i.onchange=function(){var f=i.files&&i.files[0];if(!f){window._amc_dialog_filecontent('');document.body.removeChild(i);return;}"
        js = js + "var r=new FileReader();"
        js = js + "r.onload=function(){var c=r.result;"
        if (binary) {
            // strip the `data:.../base64,` prefix so the AM side
            // gets just the base64 payload.
            js = js + "var idx=c.indexOf(',');if(idx>=0)c=c.substring(idx+1);"
        }
        js = js + "window._amc_dialog_filecontent(JSON.stringify({name:f.name,content:c}));document.body.removeChild(i);};"
        js = js + readerCall
        js = js + "};"
        js = js + "i.oncancel=function(){window._amc_dialog_filecontent('');document.body.removeChild(i);};"
        js = js + "document.body.appendChild(i);i.click();"
        js = js + "})()"
        win.Eval(js)
    }

    // Save-file via a download anchor — equivalent to WinForms'
    // SaveFileDialog combined with writing the bytes. The browser
    // doesn't let us trigger the native "Save As" picker, so we
    // create an `<a download="filename">` pointing at a data URL
    // built from `content`, click it programmatically, and clean
    // up. The user gets the OS Save-As dialog as if they clicked a
    // download link. `mimeType` is the content-type (e.g.
    // "text/plain", "application/json", "image/svg+xml").
    //
    // The handler fires immediately with "ok" once the download is
    // triggered — there's no way to know if the user accepted the
    // Save-As dialog.
    public static void SaveFile(win: Window, filename: string, content: string, mimeType: string, handler: Closure) {
        win.Bind("_amc_dialog_save", handler)
        let nameLit: string = Json.EncodeString(filename)
        let bodyLit: string = Json.EncodeString(content)
        let mimeLit: string = Json.EncodeString(mimeType)
        var js: string = "(function(){var blob=new Blob(["+bodyLit+"],{type:"+mimeLit+"});"
        js = js + "var url=URL.createObjectURL(blob);var a=document.createElement('a');"
        js = js + "a.href=url;a.download="+nameLit+";a.style.display='none';"
        js = js + "document.body.appendChild(a);a.click();"
        js = js + "setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(url);window._amc_dialog_save('ok');},100);"
        js = js + "})()"
        win.Eval(js)
    }

    // Lower-level entry point. `kind` ∈ {"info","warning","error"}
    // selects the accent color via the .amc-dialog-<kind> class.
    // `buttons` ∈ {"ok","ok-cancel","yes-no","yes-no-cancel"} selects
    // the button row.
    public static void Show(win: Window, kind: string, title: string, message: string, buttons: string, handler: Closure) {
        win.Bind("_amc_dialog_result", handler)
        // Wipe any previous dialog so opening N+1 replaces N.
        win.RemoveElement("amc-dialog")
        var btns: string = ""
        if (buttons == "ok") {
            btns = "<button class=\"amc-dialog-btn amc-dialog-primary\" data-id=\"ok\">OK</button>"
        }
        if (buttons == "ok-cancel") {
            btns = "<button class=\"amc-dialog-btn\" data-id=\"cancel\">Cancel</button>"
                 + "<button class=\"amc-dialog-btn amc-dialog-primary\" data-id=\"ok\">OK</button>"
        }
        if (buttons == "yes-no") {
            btns = "<button class=\"amc-dialog-btn\" data-id=\"no\">No</button>"
                 + "<button class=\"amc-dialog-btn amc-dialog-primary\" data-id=\"yes\">Yes</button>"
        }
        if (buttons == "yes-no-cancel") {
            btns = "<button class=\"amc-dialog-btn\" data-id=\"cancel\">Cancel</button>"
                 + "<button class=\"amc-dialog-btn\" data-id=\"no\">No</button>"
                 + "<button class=\"amc-dialog-btn amc-dialog-primary\" data-id=\"yes\">Yes</button>"
        }
        var k: string = kind
        if (k != "info" && k != "warning" && k != "error") {
            k = "info"
        }
        // Build the dialog markup. Each button's onclick closes the
        // dialog with its data-id, then dispatches the result to AM.
        let titleEsc: string = Html.Escape(title)
        let msgEsc:   string = Html.Escape(message)
        var html: string = "<dialog id=\"amc-dialog\" class=\"amc-dialog amc-dialog-" + k + "\">"
        html = html + "<div class=\"amc-dialog-head\">" + titleEsc + "</div>"
        html = html + "<div class=\"amc-dialog-body\">" + msgEsc + "</div>"
        html = html + "<div class=\"amc-dialog-row\">" + btns + "</div>"
        html = html + "</dialog>"
        // body has no id, so AppendHtml(id, …) doesn't fit; inject
        // directly via Eval against document.body. The wire-up step
        // (showModal + button onclicks + Esc-cancel) runs right after.
        let htmlLit: string = Json.EncodeString(html)
        let injectJs: string = "document.body.insertAdjacentHTML('beforeend'," + htmlLit + ");"
        let wireJs: string = "(function(){var d=document.getElementById('amc-dialog');if(!d)return;d.querySelectorAll('.amc-dialog-btn').forEach(function(b){b.onclick=function(){var v=b.getAttribute('data-id')||'cancel';d.close(v);window._amc_dialog_result(v);};});d.addEventListener('cancel',function(){window._amc_dialog_result('cancel');});d.showModal();})()"
        win.Eval(injectJs + wireJs)
    }
}

// ─── Element ───────────────────────────────────────────────
//
// A node in the HTML tree. Static builders cover the common cases
// (Stack, Row, Label, Button, Input); for anything else, drop down
// to `new Element("custom-tag")` and Attr() chains.

public class Element {
    public Tag:            string
    public Text:           string
    public Children:       List<Element>
    public AttrKeys:       List<string>
    public AttrVals:       List<string>
    // Event table — one row per (DOM event, handler, optional result
    // routing target). Explicit setters (.OnClick / .OnChange / …)
    // are sugar over .On(name, handler). The list-of-events shape lets
    // user code attach any DOM event (mouseup, wheel, drop, custom-…)
    // without facade changes — see docs/architecture.md.
    public Events:         List<string>   // DOM event names ("click", "change", …)
    public EventHandlers:  List<Closure>
    public EventResults:   List<string>   // per-event #target for return routing
    public StyleCss:       string   // cumulative inline style — see Style()
    public ResultTargetId: string   // default routing target — applies to subsequent .On*() calls

    public Element(tag: string) {
        this.Tag            = tag
        this.Text           = ""
        this.Children       = new List<Element>()
        this.AttrKeys       = new List<string>()
        this.AttrVals       = new List<string>()
        this.Events         = new List<string>()
        this.EventHandlers  = new List<Closure>()
        this.EventResults   = new List<string>()
        this.StyleCss       = ""
        this.ResultTargetId = ""
    }

    public Element SetText(t: string) {
        this.Text = t
        return this
    }

    public Element AddChild(child: Element) {
        this.Children.Add(child)
        return this
    }

    // Set an HTML attribute. The `style` name is special-cased so
    // it routes through Style() and accumulates instead of producing
    // duplicate attributes that HTML5 parsers silently drop.
    public Element Attr(name: string, value: string) {
        if (name == "style") {
            return this.Style(value)
        }
        this.AttrKeys.Add(name)
        this.AttrVals.Add(value)
        return this
    }

    public Element Id(id: string)     { return this.Attr("id", id) }
    public Element Class(cls: string) { return this.Attr("class", cls) }

    // Append a CSS declaration block to the element's inline style.
    // Multiple calls layer in declaration order; later declarations
    // win per the CSS cascade, so `.Style("color:red").Style("color:blue")`
    // resolves to blue. Use this for one-off tweaks; for reusable
    // theming attach a class via Class() and style it from a sheet.
    public Element Style(s: string) {
        if (String_Length(s) == 0) {
            return this
        }
        if (String_Length(this.StyleCss) > 0) {
            this.StyleCss = this.StyleCss + ";"
        }
        this.StyleCss = this.StyleCss + s
        return this
    }

    // Force the element to a fixed pixel size. Pass 0 on either
    // axis to leave it untouched — `Size(0, 120)` only sets height,
    // useful for sizing a Textarea / Pre while letting the parent
    // flex layout drive width.
    public Element Size(width: int, height: int) {
        if (width > 0) {
            this.Style("width:" + String_FromInt(width) + "px")
        }
        if (height > 0) {
            this.Style("height:" + String_FromInt(height) + "px")
        }
        return this
    }

    // Pin the element to absolute pixel coordinates relative to its
    // nearest positioned ancestor (or the page if none). Equivalent
    // to ui-forms' AbsoluteLayout — useful for legacy ports or
    // diagram-style UIs. Combine with Size() for full x/y/w/h
    // placement:
    //
    //   Element.Label("X").Position(40, 80).Size(120, 24)
    //
    // The CSS `position:absolute` only takes effect inside a parent
    // with `position:relative|absolute|fixed`. Use a Stack/Row/Div
    // ancestor with `.Style("position:relative")` to scope it.
    public Element Position(x: int, y: int) {
        return this.Style("position:absolute;left:" + String_FromInt(x) + "px;top:" + String_FromInt(y) + "px")
    }

    // Take whatever vertical space is left in the flex parent and
    // scroll the overflow internally. Use inside a Stack to mark
    // the child that should grow:
    //
    //   Element.Stack()
    //     .AddChild(Element.Heading("Title"))     // natural h
    //     .AddChild(longList.Fill())              // takes the rest
    //     .AddChild(footerRow)                    // natural h
    //
    // Composes with AppendInner — the patched body still scrolls
    // inside this element rather than pushing the page taller.
    public Element Fill() {
        return this.Class("amc-fill-child")
    }

    // ── Common WinForms-style properties (v0.0.5) ─────────
    //
    // Setters that mirror the WinForms designer Properties pane.
    // Each is sugar over .Attr or .Style; the names are chosen to
    // make WinForms ports read naturally.

    // WinForms .Visible — toggles `display:none`. Falsy hides the
    // element entirely (no layout space taken).
    public Element Visible(v: bool) {
        if (!v) {
            this.Style("display:none")
        }
        return this
    }

    // WinForms .Enabled — sets the HTML `disabled` attribute on
    // form controls AND dims non-input elements via opacity +
    // pointer-events. Falsy disables interaction.
    public Element Enabled(e: bool) {
        if (!e) {
            this.Attr("disabled", "disabled")
            this.Style("opacity:0.6;pointer-events:none")
        }
        return this
    }

    // WinForms .ToolTip — sets the HTML `title` attribute. Browsers
    // render a native OS-styled tooltip on hover, themed by the OS
    // (no CSS variables needed).
    public Element Tooltip(text: string) {
        return this.Attr("title", text)
    }

    // WinForms .TabIndex — keyboard focus order. Pass 0 to leave
    // the default natural-order untouched; positive values force
    // an explicit position.
    public Element TabIndex(n: int) {
        return this.Attr("tabindex", String_FromInt(n))
    }

    // WinForms .ForeColor — shorthand for `color: <css>`. Accepts
    // any CSS color: `#abc`, `rgb(…)`, `var(--amc-accent)`, named.
    public Element ForeColor(css: string) {
        return this.Style("color:" + css)
    }

    // WinForms .BackColor — shorthand for `background: <css>`.
    public Element BackColor(css: string) {
        return this.Style("background:" + css)
    }

    // WinForms .Font — shorthand for `font-family` + `font-size`.
    // Pass `""` to leave the family at the inherited default; pass
    // `0` to leave the size untouched.
    public Element Font(family: string, sizePx: int) {
        if (String_Length(family) > 0) {
            this.Style("font-family:" + family)
        }
        if (sizePx > 0) {
            this.Style("font-size:" + String_FromInt(sizePx) + "px")
        }
        return this
    }

    // WinForms .Tag — arbitrary string payload round-tripped via a
    // `data-tag` attribute. Useful for stamping IDs without using
    // the HTML `id` attribute (which must be globally unique).
    // Named DataTag to avoid clashing with the .Tag field that
    // stores the HTML element tag name (div/span/input/…).
    public Element DataTag(data: string) {
        return this.Attr("data-tag", data)
    }

    // Escape hatch: inject a raw HTML string as a child. The dev
    // is responsible for escaping. Useful when wrapping a JS lib
    // (Plotly, CodeMirror, Tabulator) that wants to render into a
    // specific markup chunk. The raw string is appended after any
    // existing children and Text content.
    //
    //   Element.Div().Id("plot").Raw("<svg width=200 height=200>…</svg>")
    public Element Raw(html: string) {
        let child: Element = new Element("__raw__")
        child.Text = html
        this.Children.Add(child)
        return this
    }

    // ── Event wiring (uniform DOM-event model) ────────────
    //
    // Every event handler is routed through Window.Bind: Page.Render
    // allocates a JS-callable name `_amc_<n>` per event, and the
    // generated `on<event>=` attribute calls it with the JSON form
    // state (auto-collected by window.__amc_collect, injected by
    // Page.ApplyTo). Handlers must return valid JSON; the return
    // is discarded unless OnResult routed it into a target.
    //
    // The explicit setters (.OnClick / .OnChange / .OnFocus / …)
    // are sugar over .On(eventName, handler). The generic form is
    // the extension hatch — custom components can attach `wheel`,
    // `drop`, `custom-foo`, anything supported by the browser.

    // Generic event binder. Attaches `handler` to the named DOM
    // event ("click", "change", "mouseenter", …). The current
    // `ResultTargetId` (set via OnResult) is captured at the time
    // of this call, so OnResult must be called BEFORE the event
    // setter to take effect.
    public Element On(eventName: string, handler: Closure) {
        this.Events.Add(eventName)
        this.EventHandlers.Add(handler)
        this.EventResults.Add(this.ResultTargetId)
        return this
    }

    // Route subsequent event handler return values into another
    // element's text content. Use with any `.On*` setter — the
    // bridge awaits the handler's returned JSON, pretty-prints it
    // (falling back to the raw string if it isn't valid JSON), and
    // writes the result into `document.getElementById(targetId)`.
    //
    //   Element.Button("Submit")
    //       .OnResult("out")            // route comes first
    //       .OnClick((req) => req)
    //   Element.Pre("").Id("out")
    //
    // For backwards compat with the v0.0.5 pre-refactor pattern
    // (`.OnClick(h).OnResult("out")` — setter THEN route), Page.Render
    // applies `ResultTargetId` to any event whose captured target
    // is empty. Pass "" to reset.
    public Element OnResult(targetId: string) {
        this.ResultTargetId = targetId
        return this
    }

    // Common DOM events — sugar over .On(name, h). The mapping
    // mirrors WinForms event names where possible:
    //
    //   WinForms.Click           → .OnClick(h)        / "click"
    //   WinForms.DoubleClick     → .OnDblClick(h)     / "dblclick"
    //   WinForms.TextChanged     → .OnChange(h)       / "change" + "input"
    //   WinForms.GotFocus/Enter  → .OnFocus(h)        / "focus"
    //   WinForms.LostFocus/Leave → .OnBlur(h)         / "blur"
    //   WinForms.MouseEnter      → .OnMouseEnter(h)   / "mouseenter"
    //   WinForms.MouseLeave      → .OnMouseLeave(h)   / "mouseleave"
    //   WinForms.KeyDown         → .OnKeyDown(h)      / "keydown"
    //   WinForms.KeyUp           → .OnKeyUp(h)        / "keyup"
    public Element OnClick(handler: Closure)      { return this.On("click",      handler) }
    public Element OnDblClick(handler: Closure)   { return this.On("dblclick",   handler) }
    public Element OnFocus(handler: Closure)      { return this.On("focus",      handler) }
    public Element OnBlur(handler: Closure)       { return this.On("blur",       handler) }
    public Element OnMouseEnter(handler: Closure) { return this.On("mouseenter", handler) }
    public Element OnMouseLeave(handler: Closure) { return this.On("mouseleave", handler) }
    public Element OnKeyDown(handler: Closure)    { return this.On("keydown",    handler) }
    public Element OnKeyUp(handler: Closure)      { return this.On("keyup",      handler) }

    // OnChange registers two underlying DOM events so the handler
    // fires on commit (change — selects, radios, checkboxes, text
    // input blur) AND on live input (textareas + text inputs).
    // The two calls dedupe themselves via the bound name; the
    // handler runs once per logical change.
    public Element OnChange(handler: Closure) {
        this.On("change", handler)
        if (this.Tag == "textarea" || this.Tag == "input") {
            this.On("input", handler)
        }
        return this
    }

    // ── Static builders ────────────────────────────────────

    // Generic block container.
    public static Element Div() {
        return new Element("div")
    }

    // Flex column with 8 px gap. Use for vertical UI layouts.
    public static Element Stack() {
        let e: Element = new Element("div")
        return e.Style("display:flex;flex-direction:column;gap:8px")
    }

    // Flex row with 8 px gap + vertical-center.
    public static Element Row() {
        let e: Element = new Element("div")
        return e.Style("display:flex;flex-direction:row;gap:8px;align-items:center")
    }

    // CSS Grid layout — equivalent to ui-forms' GridLayout. Children
    // flow left-to-right, top-to-bottom into `rows` × `cols` cells.
    // `gap` is the inter-cell spacing in pixels (use 0 for none).
    // Pass 0 for `rows` to leave row count implicit — useful when
    // you want a fixed-column grid with variable rows. Override
    // individual cell placement on children via inline style
    // (`.Style("grid-column:span 2")` etc.).
    public static Element Grid(rows: int, cols: int, gap: int) {
        let e: Element = new Element("div")
        var s: string = "display:grid;grid-template-columns:repeat(" + String_FromInt(cols) + ",1fr)"
        if (rows > 0) {
            s = s + ";grid-template-rows:repeat(" + String_FromInt(rows) + ",auto)"
        }
        s = s + ";gap:" + String_FromInt(gap) + "px"
        return e.Style(s)
    }

    // Absolutely-positioned container — equivalent to ui-forms'
    // AbsoluteLayout. Children typically use `.Position(x, y)` to
    // place themselves relative to this container; without
    // `position:relative` here, absolute children would resolve
    // against the document body instead.
    public static Element AbsoluteContainer() {
        let e: Element = new Element("div")
        return e.Style("position:relative")
    }

    // Plain text paragraph.
    public static Element Label(text: string) {
        let e: Element = new Element("p")
        return e.SetText(text)
    }

    // <h1> heading.
    public static Element Heading(text: string) {
        let e: Element = new Element("h1")
        return e.SetText(text)
    }

    // Native button. Wire via .OnClick(handler) to call back into
    // Amalgame; otherwise it's a no-op visual.
    public static Element Button(text: string) {
        let e: Element = new Element("button")
        return e.SetText(text)
    }

    // Single-line text input. `name` is the HTML `name` attribute —
    // any element with a name is picked up by the auto-bridge so
    // its value reaches OnClick handlers via the `req` JSON object.
    public static Element Input(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "text").Bind(name)
    }

    // <pre> for monospace output panels.
    public static Element Pre(text: string) {
        let e: Element = new Element("pre")
        return e.SetText(text)
    }

    // ── Form-field builders (v0.0.4) ──────────────────────
    //
    // Every element with a `name` attribute is auto-collected by
    // Page.ApplyTo's injected bridge. When an OnClick fires, the
    // handler receives `req` as a JSON object whose keys are these
    // names. Example:
    //
    //   Element.Stack()
    //     .AddChild(Element.Input("user"))
    //     .AddChild(Element.CheckBox("newsletter"))
    //     .AddChild(Element.Button("Submit")
    //       .OnClick((req: string) => req))
    //
    // Clicking the button delivers
    //   req == "{\"user\":\"alice\",\"newsletter\":true}"

    // Declarative form-key for any element. Equivalent to
    // `.Attr("name", name)` but reads more clearly at call sites
    // that build inputs from raw `new Element(...)`.
    public Element Bind(name: string) {
        return this.Attr("name", name)
    }

    // Multi-line text input. Size with `.Style("min-height:80px")`
    // or set rows/cols via `.Attr`.
    public static Element Textarea(name: string) {
        let e: Element = new Element("textarea")
        return e.Bind(name)
    }

    // <select> dropdown. Populate with `.AddChild(Element.Option(...))`.
    // The form payload reports the `value` of the selected option.
    public static Element Select(name: string) {
        let e: Element = new Element("select")
        return e.Bind(name)
    }

    // Multi-select listbox — equivalent to ui-forms' ListBox. Same
    // structure as Select() (populate with Option children), but
    // renders as an open scrolling list with multi-selection
    // enabled. `size` is the visible row count (HTML `size`
    // attribute); pass 0 to let the browser decide.
    //
    // Form payload note: <select multiple> doesn't emit a value in
    // the default __amc_collect payload — when reading the
    // selection you should attach an .OnChange handler that reads
    // `document.getElementById(name).selectedOptions` from a
    // companion JS snippet, or pass selected values manually via
    // a hidden field. Auto-collect for multi-select is on the
    // roadmap; see CHANGELOG.
    public static Element ListBox(name: string, size: int) {
        let e: Element = new Element("select")
        e.Bind(name).Attr("multiple", "multiple")
        if (size > 0) {
            e.Attr("size", String_FromInt(size))
        }
        return e
    }

    // <option> for use inside Element.Select(). `value` is what the
    // form payload reports; `label` is the visible text.
    public static Element Option(value: string, label: string) {
        let e: Element = new Element("option")
        return e.Attr("value", value).SetText(label)
    }

    // Boolean checkbox. The form payload reports `true`/`false`
    // (not the HTML default `"on"`/missing) so handlers can branch
    // directly on the parsed JSON.
    public static Element CheckBox(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "checkbox").Bind(name)
    }

    // Single-choice radio button. Multiple Radio elements sharing
    // the same `name` form a group; the form payload reports the
    // `value` of the selected one (key absent if none is checked).
    // Pair with a separate <label> if you need a clickable caption,
    // or use Element.RadioLabel(...) for a single wrapped builder.
    public static Element Radio(name: string, value: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "radio").Attr("value", value).Bind(name)
    }

    // Radio button + clickable caption — equivalent to WinForms'
    // RadioButton (which has `.Text` baked in). Renders as
    // `<label><input type=radio …> caption</label>`, so clicking
    // the text also selects the radio. Group radios by reusing the
    // same `name`:
    //
    //   Element.RadioLabel("priority", "low",    "Low")
    //   Element.RadioLabel("priority", "normal", "Normal")
    //   Element.RadioLabel("priority", "high",   "High")
    public static Element RadioLabel(name: string, value: string, caption: string) {
        let lbl: Element = new Element("label")
        lbl.Class("amc-radio")
        let inp: Element = new Element("input")
        inp.Attr("type", "radio").Attr("value", value).Bind(name)
        lbl.Children.Add(inp)
        let txt: Element = new Element("span")
        txt.SetText(caption)
        lbl.Children.Add(txt)
        return lbl
    }

    // CheckBox + clickable caption — equivalent to WinForms'
    // CheckBox.Text. Same wrapping idea as RadioLabel.
    //
    //   Element.CheckBoxLabel("newsletter", "Subscribe to newsletter")
    public static Element CheckBoxLabel(name: string, caption: string) {
        let lbl: Element = new Element("label")
        lbl.Class("amc-checkbox")
        let inp: Element = new Element("input")
        inp.Attr("type", "checkbox").Bind(name)
        lbl.Children.Add(inp)
        let txt: Element = new Element("span")
        txt.SetText(caption)
        lbl.Children.Add(txt)
        return lbl
    }

    // ── WinForms-aligned widgets (v0.0.5) ─────────────────
    //
    // The webview-side equivalents of common .NET / WinForms /
    // Visual-Studio toolbox controls. Each maps to a single HTML5
    // input type or element; OS form widgets do the heavy lifting
    // (native pickers, validation, accessibility).

    // Masked text input — equivalent to WinForms' `TextBox` with
    // `PasswordChar` set. Browsers show bullets and keep the value
    // out of the DOM-visible HTML when the user pastes.
    public static Element Password(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "password").Bind(name)
    }

    // Numeric spinbox — equivalent to WinForms' `NumericUpDown`.
    // Composite widget: <input type=number> with a column of two
    // small up/down buttons stacked vertically on the right edge,
    // matching the native WinForms look. We render the spinner
    // ourselves because WebKitGTK doesn't show the native
    // ::-webkit-inner-spin-button glyphs on Linux (unlike Chrome
    // and WebKit-on-macOS).
    //
    // Form payload reports the input value as usual. `min` / `max`
    // / `step` accept 0 to leave each unset.
    public static Element Number(name: string, min: int, max: int, step: int) {
        let wrap: Element = new Element("div")
        wrap.Class("amc-numericupdown")
        let inputId: string = "amc-num-" + name
        let inp: Element = new Element("input")
        inp.Attr("type", "number").Attr("id", inputId).Bind(name)
        if (min != 0 || max != 0) {
            inp.Attr("min", String_FromInt(min))
            inp.Attr("max", String_FromInt(max))
        }
        if (step > 0) {
            inp.Attr("step", String_FromInt(step))
        }
        let spin: Element = new Element("div")
        spin.Class("amc-num-spin")
        let up: Element = new Element("button")
        up.SetText("▲").Class("amc-num-btn amc-num-up").Attr("type", "button")
        up.Attr("onclick", "(function(){var i=document.getElementById('" + inputId + "');i.stepUp(1);i.dispatchEvent(new Event('input',{bubbles:true}));i.dispatchEvent(new Event('change',{bubbles:true}));})()")
        let down: Element = new Element("button")
        down.SetText("▼").Class("amc-num-btn amc-num-down").Attr("type", "button")
        down.Attr("onclick", "(function(){var i=document.getElementById('" + inputId + "');i.stepDown(1);i.dispatchEvent(new Event('input',{bubbles:true}));i.dispatchEvent(new Event('change',{bubbles:true}));})()")
        spin.Children.Add(up)
        spin.Children.Add(down)
        wrap.Children.Add(inp)
        wrap.Children.Add(spin)
        return wrap
    }

    // Range slider — equivalent to WinForms' `TrackBar`. Form
    // payload reports the numeric value as a string.
    public static Element Slider(name: string, min: int, max: int, step: int) {
        let e: Element = new Element("input")
        e.Attr("type", "range").Bind(name)
            .Attr("min", String_FromInt(min))
            .Attr("max", String_FromInt(max))
        if (step > 0) {
            e.Attr("step", String_FromInt(step))
        }
        return e
    }

    // Native date picker — equivalent to WinForms' `DateTimePicker`
    // (date-only). Form payload reports an ISO date string
    // (`YYYY-MM-DD`).
    public static Element DatePicker(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "date").Bind(name)
    }

    // Native time picker. Form payload reports `HH:MM` (24-hour).
    public static Element TimePicker(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "time").Bind(name)
    }

    // Native color picker — equivalent to WinForms' `ColorDialog`
    // exposed inline. Form payload reports `#RRGGBB`.
    public static Element ColorPicker(name: string) {
        let e: Element = new Element("input")
        return e.Attr("type", "color").Bind(name)
    }

    // Read-only progress indicator — equivalent to WinForms'
    // `ProgressBar`. `max` defaults to 100 when 0; pass a negative
    // value to render an indeterminate bar.
    public static Element ProgressBar(value: int, max: int) {
        let e: Element = new Element("progress")
        if (value >= 0) {
            e.Attr("value", String_FromInt(value))
        }
        if (max > 0) {
            e.Attr("max", String_FromInt(max))
        }
        return e
    }

    // Inline image. `src` accepts a `file://` URL (local asset),
    // an `https://` URL, or a `data:image/...` URL.
    public static Element Image(src: string) {
        let e: Element = new Element("img")
        return e.Attr("src", src)
    }

    // Hyperlink — equivalent to WinForms' `LinkLabel`. Clicking
    // opens the URL in the user's default OS browser via the
    // window._amc_openurl bridge bound by Page.ApplyTo. The
    // onclick attribute is emitted in-place so the webview's
    // native navigation never sees the event.
    //
    // For in-app navigation, attach an .OnClick handler — your
    // handler runs, ours doesn't.
    public static Element Link(text: string, url: string) {
        let e: Element = new Element("a")
        // The url goes into a JS string literal embedded inside the
        // double-quoted HTML onclick attribute. Json.EncodeString
        // wraps it in `"..."`; RenderElement then HTML-escapes the
        // outer `"` to `&quot;`. The browser decodes back to a
        // valid JS string literal at parse time. Webview wraps the
        // bind argv as a JSON array on the wire — Page.ApplyTo's
        // _amc_openurl closure strips that.
        let urlLit: string = Json.EncodeString(url)
        e.Attr("href", url)
        e.Attr("onclick", "event.preventDefault();if(window._amc_openurl)window._amc_openurl(" + urlLit + ");return false")
        return e.SetText(text)
    }

    // ── Additional WinForms widgets (v0.0.5 greens) ───────

    // Alias for Image(src) — matches the WinForms toolbox name.
    public static Element PictureBox(src: string) {
        return Element.Image(src)
    }

    // Alias for Div() — matches the WinForms toolbox name. Reads
    // more naturally at WinForms-port call sites.
    public static Element Panel() {
        return Element.Div()
    }

    // <fieldset> with a <legend> — equivalent to WinForms' GroupBox.
    // Theme: native browser `fieldset` styling overridden in the
    // baseline to use --amc-border / --amc-fg.
    //
    //   Element.GroupBox("Personal info")
    //       .AddChild(Element.Input("name"))
    //       .AddChild(Element.Input("email"))
    public static Element GroupBox(title: string) {
        let e: Element = new Element("fieldset")
        e.Class("amc-groupbox")
        let legend: Element = new Element("legend")
        legend.SetText(title)
        e.Children.Add(legend)
        return e
    }

    // Flex container with wrap — equivalent to WinForms'
    // FlowLayoutPanel. `direction` is "row" (LTR wrap) or
    // "column" (TTB wrap). Children flow naturally; gap is 8px.
    public static Element Flow(direction: string) {
        let e: Element = new Element("div")
        var dir: string = "row"
        if (direction == "column") {
            dir = "column"
        }
        return e.Style("display:flex;flex-direction:" + dir + ";flex-wrap:wrap;gap:8px")
    }

    // Fixed-bottom status bar — equivalent to WinForms' StatusStrip.
    // Anchors to the bottom of the viewport via `position:fixed`.
    // Add segments as children (Label, Pre, …). The baseline themes
    // it with --amc-surface background + --amc-border top border.
    public static Element StatusStrip() {
        let e: Element = new Element("footer")
        return e.Class("amc-statusstrip")
    }

    // Horizontal button bar — equivalent to WinForms' ToolStrip.
    // Themed via the `.amc-toolstrip` class in the baseline (smaller
    // padding, --amc-surface background).
    public static Element ToolStrip() {
        let e: Element = new Element("div")
        return e.Class("amc-toolstrip")
            .Style("display:flex;flex-direction:row;gap:4px;align-items:center;padding:4px 8px")
    }

    // Embedded webpage — equivalent to WinForms' WebBrowser (which
    // itself wraps IE). Useful for embedding docs / preview panels
    // inside the main app. The iframe inherits the page's
    // --amc-border by default.
    public static Element Iframe(url: string) {
        let e: Element = new Element("iframe")
        return e.Attr("src", url).Class("amc-iframe")
    }

    // Masked text input — equivalent to WinForms' MaskedTextBox.
    // `pattern` is a JS RegExp source (HTML5 `pattern` attr) used
    // for native form validation; `mode` is the soft-keyboard hint
    // ("numeric" / "tel" / "email" / "url" / "decimal" / "" for
    // default text). Browsers show the matching keyboard on mobile
    // and reject submissions that don't match the pattern.
    //
    //   Element.MaskedTextBox("phone", "[0-9 +()-]{7,}", "tel")
    public static Element MaskedTextBox(name: string, pattern: string, mode: string) {
        let e: Element = new Element("input")
        e.Attr("type", "text").Bind(name)
        if (String_Length(pattern) > 0) {
            e.Attr("pattern", pattern)
        }
        if (String_Length(mode) > 0) {
            e.Attr("inputmode", mode)
        }
        return e
    }

    // Multi-select checkbox list — equivalent to WinForms'
    // CheckedListBox. Each child is wired as a <li><label><input
    // type=checkbox name=<name> value=<itemValue>>…</label></li>
    // by Element.CheckedItem. Auto-collect reports an array of
    // checked values under `<name>` (planned v0.0.6); for now
    // attach OnChange and read via Window.Eval.
    public static Element CheckedListBox(name: string) {
        let e: Element = new Element("ul")
        return e.Class("amc-checkedlistbox").Attr("data-name", name)
    }

    // One row in a CheckedListBox. Use as a child of
    // Element.CheckedListBox(name); `value` is the form value
    // reported when checked, `label` is the visible text.
    public static Element CheckedItem(name: string, value: string, label: string) {
        let li: Element = new Element("li")
        let lbl: Element = new Element("label")
        let inp: Element = new Element("input")
        inp.Attr("type", "checkbox").Attr("value", value).Bind(name)
        lbl.Children.Add(inp)
        let txt: Element = new Element("span")
        txt.SetText(" " + label)
        lbl.Children.Add(txt)
        li.Children.Add(lbl)
        return li
    }

    // Tabular list view — equivalent to WinForms' ListView in
    // Details mode. `headers` is the column titles. `bodyId` is
    // the DOM id stamped on the inner `<tbody>` — pass "" to skip,
    // pass a non-empty string to make the body addressable by
    // `Page.AppendInner(win, bodyId, …)` / `Page.PatchInner(…)`
    // for live row updates.
    public static Element ListView(headers: List<string>, bodyId: string) {
        let e: Element = new Element("table")
        e.Class("amc-listview")
        let thead: Element = new Element("thead")
        let row:   Element = new Element("tr")
        let nh: int = headers.Count()
        for i in 0..nh {
            let th: Element = new Element("th")
            th.SetText(headers.Get(i))
            row.Children.Add(th)
        }
        thead.Children.Add(row)
        e.Children.Add(thead)
        let tbody: Element = new Element("tbody")
        tbody.Class("amc-listview-body")
        if (String_Length(bodyId) > 0) {
            tbody.Attr("id", bodyId)
        }
        e.Children.Add(tbody)
        return e
    }

    // One ListView row. Pass a list of cell values matching the
    // header count. Append as a child of the ListView; rows end
    // up inside its <tbody>.
    public static Element ListViewRow(values: List<string>) {
        let tr: Element = new Element("tr")
        let nv: int = values.Count()
        for i in 0..nv {
            let td: Element = new Element("td")
            td.SetText(values.Get(i))
            tr.Children.Add(td)
        }
        return tr
    }

    // CSS-only tab control — equivalent to WinForms' TabControl.
    // Uses radio-button + label + sibling-selector trick so no JS
    // is needed. `groupName` must be unique on the page (the
    // radios share it). Populate via .AddChild(Element.Tab(...)).
    //
    //   Element.TabControl("settings")
    //       .AddChild(Element.Tab("settings", "general", "General", general).Attr("checked","checked"))
    //       .AddChild(Element.Tab("settings", "advanced", "Advanced", advanced))
    //
    // The first Tab to set `checked="checked"` is the default
    // active panel.
    public static Element TabControl(groupName: string) {
        let e: Element = new Element("div")
        return e.Class("amc-tabs").Attr("data-group", groupName)
    }

    // One tab + its panel. Renders as an <input type=radio> +
    // <label> + <div class=amc-tab-panel> sibling triple. CSS in
    // the baseline shows the panel adjacent to the checked radio
    // and hides the rest.
    public static Element Tab(groupName: string, id: string, label: string, body: Element) {
        let wrap: Element = new Element("div")
        wrap.Class("amc-tab")
        let radio: Element = new Element("input")
        radio.Attr("type", "radio").Attr("name", groupName).Attr("id", "tab-" + groupName + "-" + id)
        let lbl: Element = new Element("label")
        lbl.Attr("for", "tab-" + groupName + "-" + id).SetText(label).Class("amc-tab-label")
        let panel: Element = new Element("div")
        panel.Class("amc-tab-panel")
        panel.Children.Add(body)
        wrap.Children.Add(radio)
        wrap.Children.Add(lbl)
        wrap.Children.Add(panel)
        return wrap
    }

    // ── TreeView (v0.0.7) ─────────────────────────────────
    //
    // Hierarchical tree of nodes — equivalent to WinForms'
    // TreeView. Built from the HTML5 <details>/<summary>
    // primitives so the expand-collapse + keyboard navigation
    // are native and free. Compose recursively:
    //
    //   Element.TreeView()
    //       .AddChild(Element.TreeNode("docs")
    //           .AddChild(Element.TreeNode("guide")
    //               .AddChild(Element.TreeLeaf("01.md"))
    //               .AddChild(Element.TreeLeaf("02.md"))))
    //       .AddChild(Element.TreeLeaf("README.md"))
    //
    // TreeNode is a folder-like expandable container (a <details>
    // wrapper); TreeLeaf is a non-expandable item (a flat div).
    // Pass `Attr("open","open")` on a TreeNode to render it
    // expanded by default.

    // Root of a tree. Themed via the .amc-treeview baseline class
    // (indent, hover, border).
    public static Element TreeView() {
        let e: Element = new Element("div")
        return e.Class("amc-treeview")
    }

    // Folder-like node — an expandable <details> with a clickable
    // <summary> labelled `caption`. Add children (more TreeNode /
    // TreeLeaf) via .AddChild — they nest correctly.
    public static Element TreeNode(caption: string) {
        let det: Element = new Element("details")
        det.Class("amc-treenode")
        let sum: Element = new Element("summary")
        sum.SetText(caption).Class("amc-treesummary")
        det.Children.Add(sum)
        return det
    }

    // Leaf node — a non-expandable line. Use for files / final
    // items. Hovers with the same accent as TreeNode rows.
    public static Element TreeLeaf(caption: string) {
        let e: Element = new Element("div")
        return e.Class("amc-treeleaf").SetText(caption)
    }

    // ── MenuBar (v0.0.8) ──────────────────────────────────
    //
    // App-level horizontal menu strip — equivalent to WinForms'
    // MenuStrip and what VS Code / Slack / Discord render with
    // HTML/CSS. The native OS-menubar version (Win32 / NSMenu /
    // GtkMenuBar) is planned as opt-in in v0.1.0; the common
    // path here renders identically on every OS and themes via
    // the standard --amc-* variables.
    //
    //   Element.MenuBar()
    //       .AddChild(Element.MenuItem("File")
    //           .AddChild(Element.MenuOption("New", "amc_new"))
    //           .AddChild(Element.MenuOption("Open…", "amc_open"))
    //           .AddChild(Element.MenuSeparator())
    //           .AddChild(Element.MenuOption("Quit", "amc_quit")))
    //       .AddChild(Element.MenuItem("Edit")
    //           .AddChild(Element.MenuOption("Undo", "amc_undo")))
    //
    // Each MenuOption emits a click that calls
    // `window.<actionName>('')`. Bind the action via
    // `Window.Bind("amc_new", handler)` after `Application.Run`.
    // (The shorter path is to set `onclick` directly via
    // `.Attr("onclick", "...")` if the action is pure JS.)

    // Horizontal <nav> container styled as a top app menubar.
    public static Element MenuBar() {
        let e: Element = new Element("nav")
        return e.Class("amc-menubar")
    }

    // One top-level menu (label + dropdown). The label is stored
    // in `Text`; AddChild appends MenuOption / MenuSeparator
    // children which become the popup content. RenderElement
    // wraps this in `<details class=amc-menu><summary>label</summary>
    // <div class=amc-menu-popup>children</div></details>` so the
    // user can use the familiar fluent AddChild without dealing
    // with the popup wrapper directly.
    public static Element MenuItem(label: string) {
        let e: Element = new Element("__menuitem__")
        return e.SetText(label)
    }

    // One row inside a MenuItem's dropdown. `actionName` is the
    // `window.<actionName>('')` call to invoke on click — bind it
    // via Window.Bind after Application.Run. Rendered as a
    // <button> inside the popup div (last child of the parent
    // <details>); AddChild on MenuItem auto-routes to the popup.
    public static Element MenuOption(label: string, actionName: string) {
        let b: Element = new Element("button")
        b.Class("amc-menu-item").SetText(label).Attr("type", "button")
        b.Attr("onclick", "this.closest('details').open=false;window." + actionName + "('');")
        return b
    }

    // Horizontal divider inside a MenuItem's dropdown — visually
    // groups related options.
    public static Element MenuSeparator() {
        let e: Element = new Element("hr")
        return e.Class("amc-menu-sep")
    }

    // ── SplitContainer (v0.0.8) ───────────────────────────
    //
    // Two-pane resizable container — equivalent to WinForms'
    // SplitContainer. Children are placed in two slots separated
    // by a draggable divider. `orientation` is "row" (left/right
    // panes, vertical divider) or "column" (top/bottom panes,
    // horizontal divider). `initialRatio` is the starting flex
    // proportion of the first pane (0.0..1.0); 0.5 = even split.
    //
    //   Element.SplitContainer("row", 0.3)
    //       .AddChild(Element.Stack()      // first pane (left)
    //           .AddChild(Element.TreeView()...))
    //       .AddChild(Element.Stack()      // second pane (right)
    //           .AddChild(...))
    //
    // The wrapper renders as
    //   <div class=amc-split amc-split-row>
    //     <div class=amc-split-pane>child[0]</div>
    //     <div class=amc-split-divider></div>
    //     <div class=amc-split-pane>child[1]</div>
    //   </div>
    // — the divider is drag-resizable via the bridge's pointer
    // handlers. Children beyond the second are ignored (use a
    // nested SplitContainer for three+ panes).
    public static Element SplitContainer(orientation: string, initialRatio: int) {
        let e: Element = new Element("__splitcontainer__")
        var orient: string = "row"
        if (orientation == "column") {
            orient = "column"
        }
        e.Class("amc-split amc-split-" + orient)
        e.Attr("data-orient", orient)
        // initialRatio is passed as an int 0..100 to avoid float
        // formatting in AM; e.g. 30 means 30% / 70% split.
        var ratio: int = initialRatio
        if (ratio < 5)  { ratio = 5 }
        if (ratio > 95) { ratio = 95 }
        e.Attr("data-ratio", String_FromInt(ratio))
        return e
    }

    // ── ContextMenu (v0.0.8) ──────────────────────────────
    //
    // Right-click anywhere on a target element to open a menu
    // anchored at the cursor. Equivalent to WinForms'
    // ContextMenuStrip. Same MenuOption / MenuSeparator builders
    // populate it.
    //
    //   let cm = Element.ContextMenu("workspace")
    //       .AddChild(Element.MenuOption("Cut", "amc_cut"))
    //       .AddChild(Element.MenuOption("Copy", "amc_copy"))
    //       .AddChild(Element.MenuSeparator())
    //       .AddChild(Element.MenuOption("Paste", "amc_paste"))
    //
    //   Element.Div().Id("workspace").Class("amc-ctx-target")
    //       .AddChild(cm)
    //       .AddChild( … the actual content … )
    //
    // The ContextMenu is initially hidden via `position:fixed;
    // display:none`. The auto-injected click-outside bridge
    // shows it on `contextmenu` events on `.amc-ctx-target`
    // ancestors, and hides it on subsequent click / Escape.
    public static Element ContextMenu(forId: string) {
        let e: Element = new Element("div")
        return e.Class("amc-ctxmenu").Attr("data-ctx-for", forId)
    }
}

// ─── Page ──────────────────────────────────────────────────
//
// Top-level HTML document holder. Render() walks the element tree,
// collects every OnClick into a parallel (name, closure) list;
// ApplyTo(window) calls SetHtml + Window.Bind in one shot.
//
// Pages are stateful (the bindings list grows during Render). Call
// Render or ApplyTo at most once per `Window` instance — re-rendering
// is supported but you'll need to Unbind the previous names yourself
// or the JS side will accumulate dead listeners.

public class Page {
    public Title:          string
    public Body:           Element
    public BindNames:      List<string>
    public BindHandlers:   List<Closure>
    public Counter:        int
    public StylesheetUrl:  string         // primary stylesheet override
    public ExtraCss:       List<string>   // extra stylesheets appended after the baseline
    public UseBaseline:    bool           // inject the baseline <style> in <head>?
    public ThemeMode:      string         // "auto" | "light" | "dark" (controls <html data-theme>)
    public LockChrome:     bool           // block right-click menu + F5/Ctrl+R/Cmd+R reloads?
    public FillFlag:       bool           // body fills the viewport (flex col, root child scrolls)

    public Page() {
        this.Title          = ""
        this.Body           = new Element("div")
        this.BindNames      = new List<string>()
        this.BindHandlers   = new List<Closure>()
        this.Counter        = 0
        this.StylesheetUrl  = ""
        this.ExtraCss       = new List<string>()
        this.UseBaseline    = true
        this.ThemeMode      = "auto"
        this.LockChrome     = true
        this.FillFlag       = true
    }

    public static Page New() {
        return new Page()
    }

    public Page SetTitle(t: string) {
        this.Title = t
        return this
    }

    public Page SetBody(e: Element) {
        this.Body = e
        return this
    }

    // Use a single external stylesheet *instead of* the baseline.
    // Pass a URL — `file:///abs/path/style.css`, `https://…`, or a
    // `data:text/css,…` data URL all work. Disables the baseline
    // implicitly; call .AddCss() if you want a stack of stylesheets.
    public Page SetStylesheet(url: string) {
        this.StylesheetUrl = url
        this.UseBaseline   = false
        return this
    }

    // Add a stylesheet on top of whatever is already there. Multiple
    // calls layer in declaration order, after the baseline.
    public Page AddCss(url: string) {
        this.ExtraCss.Add(url)
        return this
    }

    // Disable the baseline stylesheet entirely. Use when shipping a
    // CSS reset / framework (Tailwind, Pico, custom) that starts
    // from a blank slate.
    public Page NoBaseline() {
        this.UseBaseline = false
        return this
    }

    // Force the page theme regardless of the OS preference. Accepts
    // "auto" (default — defers to Page.DetectOSTheme), "light", or
    // "dark". The resolved value is written as `<html data-theme>`
    // at render time so the baseline `[data-theme=dark]` rules can
    // key off it. Custom stylesheets can do the same.
    public Page SetTheme(mode: string) {
        this.ThemeMode = mode
        return this
    }

    // Open a URL in the user's default OS browser (not in this
    // webview). Validates the scheme — only http://, https://, and
    // file:// are forwarded; anything else returns false without
    // calling the launcher. Used by the auto-injected link
    // interceptor (Page.ApplyTo) so <a href> clicks behave like a
    // native app instead of replacing the rendered page.
    public static bool OpenExternalUrl(url: string) {
        var rc: int = 1
        @c {
            rc = (i64)Amalgame_UI_Web_OpenUrl(url);
        }
        return rc == 0
    }

    // Detect the OS color scheme. Returns "light" or "dark". Order:
    //   1. `AMALGAME_UI_THEME` env var (explicit override)
    //   2. macOS `defaults read -g AppleInterfaceStyle`
    //   3. Windows `AppsUseLightTheme` registry DWORD
    //   4. Linux `gsettings ... color-scheme` (GNOME 42+)
    //   5. Linux `GTK_THEME` containing `:dark`
    //   6. Defaults to "light" if no signal.
    public static string DetectOSTheme() {
        var r: string = "light"
        @c {
            const char* p = Amalgame_UI_Web_DetectOSTheme();
            r = (code_string)(p ? p : "light");
        }
        return r
    }

    // Re-enable the webview's native context menu and the reload
    // hotkeys (F5, Ctrl+R / Cmd+R, Ctrl+Shift+R / Cmd+Shift+R).
    // OFF by default because Page.ApplyTo loads the document via
    // Window.SetHtml — there is no underlying URL to reload to, so
    // a right-click → Reload leaves the user staring at a blank
    // page until the app is restarted. Apps that navigate to real
    // URLs (Window.Navigate) and want the standard browser chrome
    // can opt back in:
    //
    //   Page.New().AllowBrowserDefaults() ...
    public Page AllowBrowserDefaults() {
        this.LockChrome = false
        return this
    }

    // Make the page fill the viewport vertically — the body becomes
    // a flex column pinned to 100vh, its first child grows to take
    // the remaining space, and any nested TabControl / Pre /
    // .Fill() element scrolls internally. No window-level vscroll.
    //
    // ON by default since v0.0.5b — app-shell behavior matches
    // what desktop apps look like. Opt out with NaturalFlow() if
    // your page is a long-form document that should scroll.
    public Page FillViewport() {
        this.FillFlag = true
        return this
    }

    // Disable FillViewport for this Page — let the document scroll
    // naturally when it overflows the viewport (the pre-v0.0.5
    // behavior). Useful for long-form text, settings pages, etc.
    public Page NaturalFlow() {
        this.FillFlag = false
        return this
    }

    // Resolve the effective theme for this render. "auto" defers to
    // Page.DetectOSTheme; "light"/"dark" pass through verbatim;
    // anything else is treated as "auto" so callers can't accidentally
    // emit garbage into the data-theme attribute.
    public string EffectiveTheme() {
        if (this.ThemeMode == "light") {
            return "light"
        }
        if (this.ThemeMode == "dark") {
            return "dark"
        }
        return Page.DetectOSTheme()
    }

    // The baseline stylesheet — a tiny modern reset + system fonts
    // + form widget polish, themed via CSS variables that flip on
    // `[data-theme=dark]` (set by Page.Render from the OS theme).
    //
    // We use the attribute selector rather than
    // `prefers-color-scheme` because WebKitGTK does not propagate
    // GNOME/KDE's color scheme to the embedded page. By detecting
    // the OS theme ourselves and writing `data-theme` on `<html>`,
    // light/dark works consistently across WebView2, WKWebView, and
    // WebKitGTK. `prefers-color-scheme` is kept as a secondary
    // fallback for cases where the user bypasses Page.Render and
    // ships their own raw HTML.
    //
    // Override individual variables in your own stylesheet rather
    // than rewriting the whole rule set:
    //
    //     :root { --amc-accent: #ff6b00 }
    //
    // Variables surface: --amc-bg, --amc-fg, --amc-muted,
    // --amc-border, --amc-surface, --amc-accent, --amc-radius.
    public static string BaselineCss() {
        var c: string = ":root{--amc-bg:#fff;--amc-fg:#1a1a1a;--amc-muted:#6a6a6a;--amc-border:#d0d0d0;--amc-surface:#f5f5f5;--amc-accent:#0066cc;--amc-radius:4px;color-scheme:light}"
        c = c + "[data-theme=dark]{--amc-bg:#1e1e1e;--amc-fg:#e8e8e8;--amc-muted:#9a9a9a;--amc-border:#404040;--amc-surface:#2a2a2a;--amc-accent:#4a9eff;color-scheme:dark}"
        c = c + "@media(prefers-color-scheme:dark){:root:not([data-theme=light]){--amc-bg:#1e1e1e;--amc-fg:#e8e8e8;--amc-muted:#9a9a9a;--amc-border:#404040;--amc-surface:#2a2a2a;--amc-accent:#4a9eff;color-scheme:dark}}"
        c = c + "*{box-sizing:border-box}"
        c = c + "html{height:100%}"
        c = c + "body{margin:0;padding:16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:14px;line-height:1.5;color:var(--amc-fg);background:var(--amc-bg);-webkit-user-select:none;user-select:none}"
        // FillViewport mode (on by default) — body becomes a 100vh
        // flex column; its first child grows to fill remaining
        // space. We intentionally don't put overflow:auto on the
        // first child: that would put a vscroll on the root layout
        // itself. Instead, the scroll should live on the deepest
        // appropriate element — TabControl tab panels, ListView
        // body, .Pre output panel. Opt out per-Page via
        // Page.NaturalFlow() if you really want the document to
        // scroll the old way.
        c = c + "body.amc-fill{height:100vh;overflow:hidden;display:flex;flex-direction:column;gap:8px}"
        c = c + "body.amc-fill>*{min-height:0}"
        c = c + "body.amc-fill>*:first-child{flex:1;display:flex;flex-direction:column;min-height:0}"
        c = c + "body.amc-fill>*:first-child>*{min-height:0}"
        // Pre / Textarea : the user-facing scroll containers when
        // they sit inside a fill-viewport layout — they get a
        // sane max-height so they don't push the page.
        c = c + "body.amc-fill pre{max-height:200px}"
        // Children marked with class amc-fill (via .Fill() helper)
        // take whatever space is left in their flex parent and
        // scroll internally.
        c = c + ".amc-fill-child{flex:1;min-height:0;overflow:auto}"
        c = c + "input,select,textarea,pre{-webkit-user-select:text;user-select:text}"
        c = c + "h1,h2,h3{margin:0 0 8px}p{margin:0 0 8px}"
        c = c + "button{padding:6px 12px;border:1px solid var(--amc-border);border-radius:var(--amc-radius);background:var(--amc-surface);color:var(--amc-fg);cursor:pointer;font:inherit}"
        c = c + "button:hover{background:var(--amc-border)}"
        c = c + "input,select,textarea{padding:6px 8px;border:1px solid var(--amc-border);border-radius:var(--amc-radius);background:var(--amc-bg);color:var(--amc-fg);font:inherit}"
        c = c + "textarea{resize:none}"
        c = c + "input:focus,select:focus,textarea:focus{outline:2px solid var(--amc-accent);outline-offset:-1px}"
        // Range slider, checkbox, radio — the generic input rule
        // wraps them in a thick bordered box that looks awful.
        // Reset to their native chromeless rendering.
        c = c + "input[type=range],input[type=checkbox],input[type=radio]{padding:0;border:none;background:transparent;outline:none;width:auto}"
        c = c + "input[type=range]{width:200px;accent-color:var(--amc-accent)}"
        c = c + "input[type=checkbox],input[type=radio]{accent-color:var(--amc-accent);width:16px;height:16px}"
        // <input type=number> hover-jitter fix + composite spinner.
        // WebKitGTK doesn't render the native ::-webkit-inner-spin-
        // button at all (Chrome / WebKit-on-macOS do), so we ship
        // explicit +/− buttons via the Element.Number composite.
        // Pin the input height so the bare input doesn't jitter
        // either; hide any residual native spinners on WebKit.
        // Kill native spin buttons everywhere — both on the input
        // and on the pseudo-elements. !important locks the cascade
        // order in case a tab-switch (display:none → display:flex)
        // re-applies the UA default appearance briefly.
        c = c + "input[type=number]{-webkit-appearance:textfield!important;appearance:textfield!important;height:32px;box-sizing:border-box}"
        c = c + "input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none!important;appearance:none!important;display:none!important;margin:0;width:0;height:0}"
        // NumericUpDown composite — input + vertically-stacked
        // up/down buttons on the right, mirroring the native
        // WinForms look. `contain:layout style` isolates the
        // composite from the parent's layout so hover-state changes
        // inside CAN NOT reflow the surrounding row. Belt-and-
        // braces with !important on the height/min-height/max-height
        // because the bug only showed up after a tab-switch cycle
        // (display:none → display:flex re-applied UA styles in a
        // different cascade order).
        c = c + ".amc-numericupdown{display:inline-flex;align-items:stretch;border-radius:var(--amc-radius);overflow:hidden;border:1px solid var(--amc-border);height:32px!important;min-height:32px!important;max-height:32px!important;background:var(--amc-bg);box-sizing:border-box;contain:layout style}"
        c = c + ".amc-numericupdown>input[type=number]{-webkit-appearance:textfield!important;appearance:textfield!important;border:none;border-radius:0;height:32px!important;flex:1;min-width:60px;padding:0 8px;background:transparent;box-sizing:border-box}"
        c = c + ".amc-numericupdown>input[type=number]:focus{outline:none}"
        c = c + ".amc-numericupdown:focus-within{outline:2px solid var(--amc-accent);outline-offset:-1px}"
        c = c + ".amc-numericupdown>.amc-num-spin{display:flex;flex-direction:column;border-left:1px solid var(--amc-border);width:18px!important;min-width:18px!important;max-width:18px!important;height:32px!important;box-sizing:border-box}"
