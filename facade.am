        // at contextmenu event.
        c = c + ".amc-ctxmenu{position:fixed;display:none;min-width:160px;background:var(--amc-bg);border:1px solid var(--amc-border);border-radius:var(--amc-radius);box-shadow:0 4px 16px rgba(0,0,0,0.3);padding:4px 0;z-index:1000;flex-direction:column;align-items:stretch}"
