import Amalgame.UI.Web

// Diagnostic for the WebKitGTK <input type=number> spinner issue.
//
// We've tried 3 CSS recipes to force the native up/down arrows
// visible in v0.0.5 — none worked, hence the composite Element.Number.
// This spike opens 7 input fields with different CSS overrides
// side-by-side so we can see which (if any) actually renders
// visible spinner buttons under the current WebKit engine.
//
// Run from a terminal with DevTools open (Ctrl+Shift+I) so you
// can inspect the pseudo-element computed styles:
//
//   bash tests/build_spike.sh spike_spinner_debug
//   ./build/spike_spinner_debug
//
// Then report which variant (A-G) shows visible buttons and we
// can fold that recipe back into the facade as
// Element.NumberNative(...) for a non-composite option.

class Program {
    public static void Main() {
        let win: Window = new Window("Spinner debug", 600, 560, true)
        if (!win.IsValid()) { return }

        var h: string = "<!DOCTYPE html><html data-theme=dark><head>"
            + "<meta charset=utf-8>"
            + "<style>"
            + "*{box-sizing:border-box}"
            + "html{height:100%}body{margin:0;padding:16px;background:#1e1e1e;color:#e8e8e8;font:14px/1.5 sans-serif;height:100vh;overflow:auto}"
            + "h1{font-size:18px;margin:0 0 12px}p{margin:0 0 12px;color:#9a9a9a;font-size:12px}"
            + "fieldset{border:1px solid #404040;border-radius:4px;margin:0 0 10px;padding:8px 12px}"
            + "legend{color:#9a9a9a;font-size:12px;padding:0 4px}"
            + "input[type=number]{padding:6px 8px;border:1px solid #404040;border-radius:4px;background:#1e1e1e;color:#e8e8e8;font:inherit;width:120px;height:32px;box-sizing:border-box}"
            // Variant overrides — each fieldset has a unique class.
            + ".v-a input::-webkit-inner-spin-button{opacity:1}"
            + ".v-b input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button;opacity:1;height:100%}"
            + ".v-c input::-webkit-inner-spin-button{display:inline-block;opacity:1;visibility:visible}"
            + ".v-d input{-webkit-appearance:number-input}"
            + ".v-e input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button !important;opacity:1 !important;width:16px !important;height:100% !important;background:#444 !important}"
            + ".v-f input{appearance:auto}"
            + ".v-g input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button;opacity:1;background:linear-gradient(180deg,#666 0%,#666 49%,#404040 49%,#404040 51%,#666 51%,#666 100%);width:14px;height:32px}"
            + "</style></head><body>"
            + "<h1>WebKitGTK input[type=number] spinner debug</h1>"
            + "<p>Hover each field; check which one shows visible up/down buttons even when NOT hovered. Open DevTools and inspect ::-webkit-inner-spin-button to compare computed styles. Report the working variant back so we can use it for Element.NumberNative.</p>"
            + "<fieldset><legend>baseline — no override</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-a><legend>A — opacity:1 only</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-b><legend>B — appearance:inner-spin-button + opacity:1 + height:100%</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-c><legend>C — display:inline-block + visibility:visible + opacity:1</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-d><legend>D — input -webkit-appearance:number-input</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-e><legend>E — !important combo + width/height/bg</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-f><legend>F — input appearance:auto</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<fieldset class=v-g><legend>G — hand-rolled background gradient (fake spinner glyph)</legend><input type=number value=10 min=0 max=100></fieldset>"
            + "<p>If none of A-G shows persistent buttons, WebKitGTK doesn't expose ::-webkit-inner-spin-button rendering at all and the composite widget stays the right call.</p>"
            + "</body></html>"

        win.SetHtml(h)
        win.Run()
        win.Destroy()
    }
}
