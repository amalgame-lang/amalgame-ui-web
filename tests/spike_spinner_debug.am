import Amalgame.UI.Web

// Diagnostic for the WebKitGTK <input type=number> spinner issue.
//
// We've tried 3 CSS recipes to force the native up/down arrows
// visible in v0.0.5 — none worked, hence the composite Element.Number.
// This spike opens 7 input fields with different CSS overrides
// side-by-side so we can see which (if any) actually renders
// visible spinner buttons under the current WebKit engine.
//
// Run from a terminal with DevTools open (Ctrl+Shift+I) so you
// can inspect the pseudo-element computed styles:
//
//   bash tests/build_spike.sh spike_spinner_debug
//   ./build/spike_spinner_debug
//
// Then report which variant (A-G) shows visible buttons and we
// can fold that recipe back into the facade as
// Element.NumberNative(...) for a non-composite option.

class Program {
    public static void Main() {
        let win: Window = new Window("Spinner debug", 600, 560, true)
        if (!win.IsValid()) { return }

        // amc parser quirk: multi-line `var s = "a" + "b" + "c"`
        // sequencing across newlines silently drops everything past
        // the first literal. Build the string with explicit `s = s + …`
        // statements instead so each concatenation is its own stmt.
        var h: string = "<!DOCTYPE html><html data-theme=dark><head>"
        h = h + "<meta charset=utf-8>"
        h = h + "<style>"
        h = h + "*{box-sizing:border-box}"
        h = h + "html{height:100%}body{margin:0;padding:16px;background:#1e1e1e;color:#e8e8e8;font:14px/1.5 sans-serif;height:100vh;overflow:auto}"
        h = h + "h1{font-size:18px;margin:0 0 12px}p{margin:0 0 12px;color:#9a9a9a;font-size:12px}"
        h = h + "fieldset{border:1px solid #404040;border-radius:4px;margin:0 0 10px;padding:8px 12px}"
        h = h + "legend{color:#9a9a9a;font-size:12px;padding:0 4px}"
        h = h + "input[type=number]{padding:6px 8px;border:1px solid #404040;border-radius:4px;background:#1e1e1e;color:#e8e8e8;font:inherit;width:120px;height:32px;box-sizing:border-box}"
        h = h + ".v-a input::-webkit-inner-spin-button{opacity:1}"
        h = h + ".v-b input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button;opacity:1;height:100%}"
        h = h + ".v-c input::-webkit-inner-spin-button{display:inline-block;opacity:1;visibility:visible}"
        h = h + ".v-d input{-webkit-appearance:number-input}"
        h = h + ".v-e input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button !important;opacity:1 !important;width:16px !important;height:100% !important;background:#444 !important}"
        h = h + ".v-f input{appearance:auto}"
        h = h + ".v-g input::-webkit-inner-spin-button{-webkit-appearance:inner-spin-button;opacity:1;background:linear-gradient(180deg,#666 0%,#666 49%,#404040 49%,#404040 51%,#666 51%,#666 100%);width:14px;height:32px}"
        h = h + "</style></head><body>"
        h = h + "<h1>WebKitGTK input[type=number] spinner debug</h1>"
        h = h + "<p>Hover each field; check which one shows visible up/down buttons even when NOT hovered. Open DevTools (Ctrl+Shift+I) and inspect ::-webkit-inner-spin-button to compare computed styles.</p>"
        h = h + "<fieldset><legend>baseline (no override)</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-a><legend>A &mdash; opacity:1 only</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-b><legend>B &mdash; appearance:inner-spin-button + opacity:1 + height:100%</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-c><legend>C &mdash; display:inline-block + visibility:visible + opacity:1</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-d><legend>D &mdash; input -webkit-appearance:number-input</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-e><legend>E &mdash; !important combo + width/height/bg</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-f><legend>F &mdash; input appearance:auto</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<fieldset class=v-g><legend>G &mdash; hand-rolled background gradient (fake spinner glyph)</legend><input type=number value=10 min=0 max=100></fieldset>"
        h = h + "<p>If none of A-G shows persistent buttons, WebKitGTK omits the pseudo-element rendering entirely and the composite Element.Number is the right call.</p>"
        h = h + "</body></html>"

        win.SetHtml(h)
        win.Run()
        win.Destroy()
    }
}
