import Amalgame.UI.Web

// Spike for amalgame-ui-web v0.0.3 — HTML builder + auto-Bind.
//
// NB: written without fluent chains because amc cgen mis-lowers
// `Type.Static().Method()` into `Type_Static()_Method()` (bug to
// file). Once that's fixed, switch back to the chain style — the
// API supports it intentionally.

class Program {
    public static void Main() {
        let win: Window = new Window("Amalgame.UI.Web — Builder demo", 700, 500, true)
        if (!win.IsValid()) {
            return
        }

        // Build the page bottom-up with intermediate vars.
        let head: Element = Element.Heading("v0.0.3 HTML builder")
        let lbl: Element  = Element.Label("AM-side composition, no inline HTML strings")
        let inp: Element  = Element.Input("name")
        inp.Attr("placeholder", "your name")

        let greetFn: Closure  = (req: string) => Json.EncodeString("Hello from Amalgame!")
        let revFn:   Closure  = (req: string) => Json.EncodeString("(reverse not wired yet)")

        let btnGreet: Element = Element.Button("Greet")
        btnGreet.OnClick(greetFn)
        let btnRev:   Element = Element.Button("Reverse")
        btnRev.OnClick(revFn)

        let row: Element = Element.Row()
        row.AddChild(btnGreet)
        row.AddChild(btnRev)

        let out: Element = Element.Pre("(click a button)")
        out.Id("out")

        let body: Element = Element.Stack()
        body.AddChild(head)
        body.AddChild(lbl)
        body.AddChild(inp)
        body.AddChild(row)
        body.AddChild(out)

        let page: Page = Page.New()
        page.SetTitle("Builder demo")
        page.SetBody(body)

        page.ApplyTo(win)

        // Bridge: when a button is clicked, look up its bound name
        // from the onclick attr, invoke it, drop the result into
        // <pre id=out>. v0.0.4 will replace this with a proper
        // .OnClick wiring that targets a result-sink declaratively.
        win.Init("document.addEventListener('click', async (e) => { if (e.target.tagName === 'BUTTON') { const m = (e.target.getAttribute('onclick') || '').match(/window\\.(\\w+)/); if (m) { e.preventDefault(); const r = await window[m[1]](); document.getElementById('out').textContent = r; } } }, true)")

        win.Run()
        win.Destroy()
    }
}
