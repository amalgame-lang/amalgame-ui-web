import Amalgame.UI.Web

// Spike for amalgame-ui-web v0.0.4 — form reading via Element.Bind.
//
// Demonstrates the new form-field builders (Textarea, Select,
// CheckBox, Radio) and the auto-injected window.__amc_collect()
// bridge. The Submit button handler receives a JSON object with
// every input/select/textarea[name] value pre-parsed.
//
// Expected on submit:
//   { "user":"…", "message":"…", "newsletter":true|false,
//     "priority":"low"|"normal"|"high", "theme":"light"|"dark"|"auto" }
// rendered as JSON inside the <pre id=out> output panel.

class Program {
    public static void Main() {
        let win: Window = new Window("Amalgame.UI.Web — Form demo", 720, 560, true)
        if (!win.IsValid()) {
            return
        }

        let page: Page = Page.New()
            .SetTitle("Form demo")
            .SetBody(
                Element.Stack()
                    .AddChild(Element.Heading("v0.0.4 form reading"))
                    .AddChild(Element.Label("Edit any field, then click Submit. The handler receives the form as a JSON object."))
                    .AddChild(Element.Input("user").Attr("placeholder", "Your name"))
                    .AddChild(Element.Textarea("message").Attr("placeholder", "A message").Style("min-height:80px"))
                    .AddChild(
                        Element.Row()
                            .AddChild(Element.Label("Theme:"))
                            .AddChild(
                                Element.Select("theme")
                                    .AddChild(Element.Option("light", "Light"))
                                    .AddChild(Element.Option("dark",  "Dark"))
                                    .AddChild(Element.Option("auto",  "Auto"))
                            )
                    )
                    .AddChild(
                        Element.Row()
                            .AddChild(Element.Label("Priority:"))
                            .AddChild(Element.Radio("priority", "low"))
                            .AddChild(Element.Label("low"))
                            .AddChild(Element.Radio("priority", "normal").Attr("checked", "checked"))
                            .AddChild(Element.Label("normal"))
                            .AddChild(Element.Radio("priority", "high"))
                            .AddChild(Element.Label("high"))
                    )
                    .AddChild(
                        Element.Row()
                            .AddChild(Element.CheckBox("newsletter"))
                            .AddChild(Element.Label("Subscribe to newsletter"))
                    )
                    .AddChild(
                        Element.Row()
                            .AddChild(
                                Element.Button("Submit")
                                    .OnClick((req: string) => req)
                            )
                    )
                    .AddChild(Element.Pre("(submit to see the form payload)").Id("out"))
            )

        page.ApplyTo(win)

        // Spike-only bridge: intercept button clicks so the handler's
        // return value can land in #out. The inline onclick already
        // calls the bound handler with the form payload — we mirror
        // that call here to capture the result. v0.0.5+ may add a
        // declarative `.OnResult(targetId)` to remove this dance.
        win.Init("document.addEventListener('click', async (e) => { if (e.target.tagName === 'BUTTON') { const m = (e.target.getAttribute('onclick') || '').match(/window\\.(\\w+)/); if (m) { e.preventDefault(); const r = await window[m[1]](JSON.stringify(window.__amc_collect())); document.getElementById('out').textContent = JSON.stringify(JSON.parse(r), null, 2); } } }, true)")

        win.Run()
        win.Destroy()
    }
}
