import Amalgame.UI.Web

// v0.0.9 spike — RichTextBox + MonthCalendar + Component pattern.
//
// Shows the two new widgets side by side, plus a custom Component
// (the "LabeledInput" class below) demonstrating the recommended
// pattern for reusable widgets.

// ── Component pattern ───────────────────────────────────────
//
// Convention: define a class with a Render() method that returns
// an Element. Compose it into a tree via `.AddChild(myWidget.Render())`.
// No abstract base / interface — Amalgame's static dispatch makes
// virtual overrides on a parent unreliable, so a flat convention
// keeps things predictable.
//
// Ship reusable widgets as a regular Amalgame package; consumers
// pull them via `amc package add my-team-widgets` and instantiate
// them like any class.

public class LabeledInput {
    public Caption: string
    public Name:    string

    public LabeledInput(caption: string, name: string) {
        this.Caption = caption
        this.Name    = name
    }

    public Element Render() {
        return Element.Row()
            .AddChild(Element.Label(this.Caption).Size(120, 0))
            .AddChild(Element.Input(this.Name))
    }
}

class Program {
    // Component pattern in action — build a stack of three
    // LabeledInput widgets. Split into a static helper so the
    // `new LabeledInput(...).Render()` chain has its `let`
    // intermediates (amc doesn't yet codegen the inline chain
    // correctly).
    public static Element BuildPersonForm() {
        let first: LabeledInput = new LabeledInput("First name:", "first")
        let last:  LabeledInput = new LabeledInput("Last name:",  "last")
        let mail:  LabeledInput = new LabeledInput("Email:",      "email")
        return Element.Stack()
            .AddChild(first.Render())
            .AddChild(last.Render())
            .AddChild(mail.Render())
    }

    public static void Main() {
        let win: Window = new Window("amalgame-ui-web v0.0.9 — RichTextBox + MonthCalendar + Component", 900, 600, true)
        if (!win.IsValid()) { return }

        let body: Element = Element.Stack()
            .AddChild(Element.Heading("v0.0.9 — RichTextBox + MonthCalendar + Component"))

            .AddChild(Element.GroupBox("RichTextBox (contenteditable, captures inline formatting)")
                .AddChild(Element.RichTextBox("notes")
                    .Attr("placeholder-text", "Type — paste rich text from another app — Ctrl-B for bold, etc.")
                    .Style("min-height:100px")))

            .AddChild(Element.GroupBox("MonthCalendar — click a day to select it")
                .AddChild(Element.Row()
                    .AddChild(Element.MonthCalendar("birthday", 2026, 5))
                    .AddChild(Element.MonthCalendar("anniversary", 2026, 6))))

            // Component pattern usage — instantiate via `let`
            // intermediates (amc's static-dispatch on `new X(...).Method()`
            // chain misbehaves; standard workaround documented in
            // 04-layout-and-theme.md "Fluent chain limits").
            .AddChild(Element.GroupBox("Component pattern — LabeledInput widget reused").AddChild(Program.BuildPersonForm()))

            .AddChild(Element.Row()
                .AddChild(Element.Button("Submit")
                    .OnClick((req: string) => req)
                    .OnResult("out")))
            .AddChild(Element.Pre("(submit to see all form values)").Id("out").Size(0, 140))

        let page: Page = Page.New().SetTitle("v0.0.9 spike").AutoTheme(true).SetBody(body)
        page.ApplyTo(win)
        win.Run()
        win.Destroy()
    }
}
