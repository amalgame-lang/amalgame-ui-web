                    .AddChild(Element.Label("→  appends a new row via Page.AppendInner — no full re-render"))))
            .AddChild(Element.GroupBox("LinkLabel + PictureBox")
                .AddChild(Element.Row()
                    .AddChild(Element.Link("Open the Amalgame language site", "https://example.com"))
                    .AddChild(Element.Label("→  click — opens in your browser"))))
            .AddChild(Element.GroupBox("WebBrowser (iframe)")
                .AddChild(Element.Iframe("https://example.com").Size(0, 200)))
            .AddChild(Element.GroupBox("Event playground — focus / blur / type / Enter")
                .AddChild(Element.Input("playground")
                    .Attr("placeholder", "Try focusing, typing, blurring — every event fires")
                    .Tooltip("Each event echoes into the output below")
                    .OnFocus((req: string) => req)
                    .OnBlur((req: string) => req)
                    .OnChange((req: string) => req)
                    .OnKeyDown((req: string) => req)
                    .OnResult("out-events"))
                .AddChild(Element.Pre("(focus / type to see events)").Id("out-events").Size(0, 90)))

        // ── Tab 5 — Dialogs (MessageBox / Confirm / YesNoCancel) ──
        let dialogs: Element = Element.Stack()
            .AddChild(Element.Heading("Modal dialogs"))
            .AddChild(Element.GroupBox("Info / Warning / Error — single OK button")
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Info").Attr("onclick", "window.amc_dlg_info('');"))
                    .AddChild(Element.Button("Warning").Attr("onclick", "window.amc_dlg_warning('');"))
                    .AddChild(Element.Button("Error").Attr("onclick", "window.amc_dlg_error('');"))))
            .AddChild(Element.GroupBox("Confirm — OK / Cancel")
                .AddChild(Element.Button("Confirm quit").Attr("onclick", "window.amc_dlg_confirm('');")))
            .AddChild(Element.GroupBox("Yes / No / Cancel — save dialog")
                .AddChild(Element.Button("Save changes?").Attr("onclick", "window.amc_dlg_savecancel('');")))
            .AddChild(Element.Pre("(click a button — result echoes here)").Id("dlg-result").Size(0, 110))

        // ── Tab 6 — v0.0.7 (TreeView + File dialogs) ────────
        let tree: Element = Element.TreeView()
            .AddChild(Element.TreeNode("src").Attr("open", "open")
                .AddChild(Element.TreeNode("parser")
                    .AddChild(Element.TreeLeaf("ast.am"))
                    .AddChild(Element.TreeLeaf("parser.am")))
                .AddChild(Element.TreeNode("generator")
                    .AddChild(Element.TreeLeaf("c_gen.am")))
                .AddChild(Element.TreeLeaf("main.am")))
            .AddChild(Element.TreeNode("docs")
                .AddChild(Element.TreeLeaf("README.md"))
                .AddChild(Element.TreeLeaf("CHANGELOG.md")))
            .AddChild(Element.TreeLeaf("amalgame.toml"))

        let v07: Element = Element.Stack()
            .AddChild(Element.Heading("v0.0.7 — TreeView + file dialogs"))
            .AddChild(Element.GroupBox("TreeView (folders / files style)")
                .AddChild(tree))
            .AddChild(Element.GroupBox("File dialogs")
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Open file").Attr("onclick", "window.amc_open_file('');"))
                    .AddChild(Element.Button("Save 'demo.txt'").Attr("onclick", "window.amc_save_file('');")))
                .AddChild(Element.Pre("(open a file or trigger a save — result echoes here)").Id("file-result").Size(0, 60)))

        // ── Tab 7 — v0.0.8 (SplitContainer + ContextMenu + FileReader) ──
        let splitLeft: Element = Element.Stack()
            .AddChild(Element.Heading("Sidebar").Style("margin:0;font-size:13px"))
            .AddChild(Element.TreeView()
                .AddChild(Element.TreeNode("Items").Attr("open", "open")
                    .AddChild(Element.TreeLeaf("Alpha"))
                    .AddChild(Element.TreeLeaf("Beta"))
                    .AddChild(Element.TreeLeaf("Gamma"))))

        let splitCtxMenu: Element = Element.ContextMenu("v08-ctx-target")
            .AddChild(Element.MenuOption("Cut",   "amc_v08_cut"))
            .AddChild(Element.MenuOption("Copy",  "amc_v08_copy"))
            .AddChild(Element.MenuOption("Paste", "amc_v08_paste"))
            .AddChild(Element.MenuSeparator())
            .AddChild(Element.MenuOption("Select all", "amc_v08_selall"))

        let splitRight: Element = Element.Div()
            .Id("v08-ctx-target")
            .Class("amc-ctx-target")
            .Style("padding:8px")
            .AddChild(splitCtxMenu)
            .AddChild(Element.Heading("Right pane — right-click for context menu").Style("margin:0;font-size:13px"))
            .AddChild(Element.Label("Try the SplitContainer divider — drag horizontally to resize the panes.").Style("color:var(--amc-muted);font-size:12px"))
            .AddChild(Element.Pre("(context menu choice echoes here)").Id("v08-ctx-result").Size(0, 60))

        let v08: Element = Element.Stack()
            .AddChild(Element.Heading("v0.0.8 — SplitContainer + ContextMenu + FileReader"))
            .AddChild(Element.GroupBox("SplitContainer (drag the vertical divider)")
                .AddChild(Element.SplitContainer("row", 35)
                    .AddChild(splitLeft)
                    .AddChild(splitRight)
                    .Style("height:200px;border:1px solid var(--amc-border);border-radius:var(--amc-radius)")))
            .AddChild(Element.GroupBox("Dialog.OpenFileContent — reads the file content via FileReader")
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Open file content").Attr("onclick", "window.amc_v08_open_content('');")))
                .AddChild(Element.Pre("(open a text file — name + first 200 chars echo here)").Id("v08-content-result").Size(0, 80)))

        // ── Tab 8 — v0.0.9 (RichTextBox + MonthCalendar + Component) ──
        // Component pattern: inline `new X(...).Render()` since
        // amc v0.8.16 (earlier versions needed `let` intermediates).
        let v09Personal: Element = Element.Stack()
            .AddChild(new LabeledInput("First name:", "v09-first").Render())
            .AddChild(new LabeledInput("Last name:",  "v09-last").Render())
            .AddChild(new LabeledInput("Email:",      "v09-email").Render())
        let v09: Element = Element.Stack()
            .AddChild(Element.Heading("v0.0.9 — RichTextBox + MonthCalendar + Component pattern"))
            .AddChild(Element.GroupBox("RichTextBox (contenteditable — paste rich text, Ctrl-B/I/U)")
                .AddChild(Element.RichTextBox("v09-notes")
                    .Attr("placeholder-text", "Write — paste — bold — italic…")
                    .Style("min-height:80px")))
            .AddChild(Element.GroupBox("MonthCalendar (inline picker — click a day)")
                .AddChild(Element.Row()
                    .AddChild(Element.MonthCalendar("v09-birthday",    2026, 5))
                    .AddChild(Element.MonthCalendar("v09-anniversary", 2026, 6))))
            .AddChild(Element.GroupBox("Component pattern — LabeledInput class reused × 3")
                .AddChild(v09Personal))
            .AddChild(Element.Row()
                .AddChild(Element.Button("Submit v0.0.9 form")
                    .OnClick((req: string) => req)
                    .OnResult("v09-result")))
            .AddChild(Element.Pre("(click Submit to see all v0.0.9 form values)").Id("v09-result").Size(0, 140))

        // ── Compose the tabbed page ──────────────────────────
        // FillViewport() pins the body to 100vh — the TabControl
        // grows to fill remaining vertical space and scrolls
        // internally, so we don't get a window-level scrollbar
        // when one tab's content is taller than the viewport.
        // App-level MenuBar (v0.0.8) — File / View / Help. Wires
        // are bound below after ApplyTo.
        let menubar: Element = Element.MenuBar()
            .AddChild(Element.MenuItem("File")
                .AddChild(Element.MenuOption("New",   "amc_menu_new"))
                .AddChild(Element.MenuOption("Open…", "amc_menu_open"))
                .AddChild(Element.MenuOption("Save…", "amc_menu_save"))
                .AddChild(Element.MenuSeparator())
                .AddChild(Element.MenuOption("Quit",  "amc_menu_quit")))
            .AddChild(Element.MenuItem("View")
                .AddChild(Element.MenuOption("Toggle theme info", "amc_menu_theme")))
            .AddChild(Element.MenuItem("Help")
                .AddChild(Element.MenuOption("About", "amc_menu_about")))

        let page: Page = Page.New()
            .SetTitle("amalgame-ui-web — gallery")
            .FillViewport()
            .FullBleed()
            .AutoTheme(true)
            .OnThemeChange((mode: string) => {
                Console.WriteLine("[gallery] theme changed: " + mode)
                return ""
            })
            .SetBody(
                Element.Stack()
                    .Style("gap:0;height:100%")
                    .AddChild(menubar)
                    .AddChild(Element.Stack().Style("padding:12px;flex:1;min-height:0;overflow:hidden")
                        .AddChild(Element.Heading("amalgame-ui-web v0.0.5 → v0.0.9 — widget gallery"))
                        .AddChild(Element.Label("Switch tabs to browse the categories. Theme flips live when your OS theme changes (matchMedia + 1.5s polling fallback)."))
                        .AddChild(Element.TabControl("gal")
                            .AddChild(Element.Tab("gal", "inputs", "Text inputs", textInputs)
                                .Attr("checked", "checked"))
                            .AddChild(Element.Tab("gal", "choices", "Selection", choiceWidgets))
                            .AddChild(Element.Tab("gal", "layouts", "Layouts", layouts))
                            .AddChild(Element.Tab("gal", "tabular", "Tables + events", tabular))
                            .AddChild(Element.Tab("gal", "dialogs", "Dialogs", dialogs))
                            .AddChild(Element.Tab("gal", "v07", "v0.0.7", v07))
                            .AddChild(Element.Tab("gal", "v08", "v0.0.8", v08))
                            .AddChild(Element.Tab("gal", "v09", "v0.0.9", v09))))
                    .AddChild(Element.StatusStrip()
                        .AddChild(Element.Label("Ready"))
                        .AddChild(Element.Label("|"))
                        .AddChild(Element.Label("ui-web v0.0.5 → v0.0.9 rollup"))
                        .AddChild(Element.Label("|"))
                        .AddChild(Element.Label("OS-themed (light/dark live)")))
            )

        // Bind the "Add row" handler BEFORE ApplyTo so the binding
        // is in the win's bind table when the page loads — webview
        // injects the shim during page load. The button itself
        // carries an onclick attribute calling window.amc_addrow,
        // so no Eval / DOMContentLoaded race involved.
        //
        // Each click captures the closure over `page` and `win`,
        // builds a fresh row, and Page.AppendInner injects it into
        // the ListView body without re-rendering the rest.
        var addCount: int = 0
        win.Bind("amc_addrow", (req: string) => {
            addCount = addCount + 1
            Console.WriteLine("[gallery] amc_addrow #" + String_FromInt(addCount))
            let r: List<string> = [
                "new-" + String_FromInt(addCount) + ".txt",
                "0 KB",
                "just now"
            ]
            page.AppendInner(win, "files-body", Element.ListViewRow(r))
            return "true"
        })

        // Dialog launchers — each button on tab 5 calls these.
        // The closure captures `win` so it can drive Dialog.Show.
        // Result handlers feed the choice back into #dlg-result via
        // Eval (a fully-AM way would be a sibling Bind that uses
        // page.PatchInner, but Eval keeps this snippet short).
        win.Bind("amc_dlg_info", (req: string) => {
            Dialog.Info(win, "Information", "All systems nominal.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Info result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_warning", (req: string) => {
            Dialog.Warning(win, "Warning", "This action cannot be undone.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Warning result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_error", (req: string) => {
            Dialog.Error(win, "Connection lost", "Failed to reach the server.\nPlease check your network.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Error result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_confirm", (req: string) => {
            Dialog.Confirm(win, "Quit?", "Unsaved changes will be lost.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Confirm result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_savecancel", (req: string) => {
            Dialog.YesNoCancel(win, "Save changes?", "Do you want to save before quitting?", (r: string) => {
                win.SetInnerHtml("dlg-result", "Save dialog result: " + r)
                return ""
            })
            return "true"
        })

        // v0.0.7 — file dialogs launchers.
        win.Bind("amc_open_file", (req: string) => {
            Dialog.OpenFile(win, "", (name: string) => {
                if (String_Length(name) > 0) {
                    win.SetInnerHtml("file-result", "Opened: " + name)
                } else {
                    win.SetInnerHtml("file-result", "(cancelled)")
                }
                return ""
            })
            return "true"
        })
        win.Bind("amc_save_file", (req: string) => {
            Dialog.SaveFile(win, "demo.txt", "Hello from amalgame-ui-web v0.0.7!\nGenerated " + String_FromInt(0) + " milliseconds ago.\n", "text/plain", (r: string) => {
                win.SetInnerHtml("file-result", "Save triggered: " + r)
                return ""
            })
            return "true"
        })

        // v0.0.8 — MenuBar handlers.
        win.Bind("amc_menu_new",   (req: string) => { Console.WriteLine("[menu] New")    return "" })
        win.Bind("amc_menu_open",  (req: string) => {
            Dialog.OpenFile(win, "", (name: string) => {
                Console.WriteLine("[menu] Open: " + name)
                return ""
            })
            return ""
        })
        win.Bind("amc_menu_save",  (req: string) => {
            Dialog.SaveFile(win, "notes.txt", "Saved from the gallery MenuBar > File > Save.", "text/plain", (r: string) => {
                Console.WriteLine("[menu] Save: " + r)
                return ""
            })
            return ""
        })
        win.Bind("amc_menu_quit",  (req: string) => { win.Terminate() return "" })
        win.Bind("amc_menu_theme", (req: string) => {
            Console.WriteLine("[menu] (theme info — change your OS theme to see AutoTheme flip live)")
            return ""
        })
        win.Bind("amc_menu_about", (req: string) => {
            Dialog.Info(win, "About", "amalgame-ui-web — webview-based GUI binding for Amalgame.\nRolled-up gallery v0.0.5 → v0.0.9.", (r: string) => "")
            return ""
        })

        // v0.0.8 — ContextMenu handlers (right-click on the
        // right pane of the SplitContainer).
        win.Bind("amc_v08_cut",    (req: string) => { win.SetInnerHtml("v08-ctx-result", "Context: Cut")        return "" })
        win.Bind("amc_v08_copy",   (req: string) => { win.SetInnerHtml("v08-ctx-result", "Context: Copy")       return "" })
        win.Bind("amc_v08_paste",  (req: string) => { win.SetInnerHtml("v08-ctx-result", "Context: Paste")      return "" })
        win.Bind("amc_v08_selall", (req: string) => { win.SetInnerHtml("v08-ctx-result", "Context: Select all") return "" })

        // v0.0.8 — OpenFileContent (FileReader reads the bytes).
        win.Bind("amc_v08_open_content", (req: string) => {
            Dialog.OpenFileContent(win, "", false, (payload: string) => {
                if (String_Length(payload) == 0) {
                    win.SetInnerHtml("v08-content-result", "(cancelled)")
                    return ""
                }
                // payload = {"name":"...","content":"..."} — truncate
                // to keep the echo readable.
                var preview: string = payload
                if (String_Length(preview) > 220) {
                    preview = String_Substring(preview, 0, 220) + "…"
                }
                win.SetInnerHtml("v08-content-result", preview)
                return ""
            })
            return ""
        })

        page.ApplyTo(win)
        win.Run()
        win.Destroy()
    }
}
