import Amalgame.UI.Web

// Visual gallery — opens a real webview window that surfaces every
// widget added in v0.0.5, grouped by WinForms toolbox category. Run
// to *see* the controls under the OS theme; the output panel at the
// bottom of each block echoes the form payload when you click the
// section's Submit button.
//
//   bash tests/build_spike.sh spike_gallery && ./build/spike_gallery
//
// Tabs split the gallery into manageable screens so the window
// height stays reasonable on a laptop.

class Program {
    public static void Main() {
        let win: Window = new Window("amalgame-ui-web v0.0.5 — gallery", 920, 720, true)
        if (!win.IsValid()) {
            return
        }

        // ── Tab 1 — Text inputs + buttons ────────────────────
        let textInputs: Element = Element.Stack()
            .AddChild(Element.Heading("Text inputs"))
            .AddChild(Element.GroupBox("TextBox / Password / MaskedTextBox")
                .AddChild(Element.Input("user").Attr("placeholder", "Name (TextBox)"))
                .AddChild(Element.Password("pwd").Attr("placeholder", "Password"))
                .AddChild(Element.MaskedTextBox("phone", "[0-9 +()-]{7,}", "tel")
                    .Attr("placeholder", "+33 1 23 45 67 89 (MaskedTextBox tel)"))
                .AddChild(Element.MaskedTextBox("zip", "[0-9]{5}", "numeric")
                    .Attr("placeholder", "75001 (MaskedTextBox numeric)"))
                .AddChild(Element.Textarea("msg")
                    .Attr("placeholder", "Multiline Textarea")
                    .Size(0, 80)))
            .AddChild(Element.GroupBox("Numeric + sliders")
                .AddChild(Element.Row()
                    .AddChild(Element.Label("NumericUpDown:").Size(140, 0))
                    .AddChild(Element.Number("qty", 1, 100, 1)))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Slider:").Size(140, 0))
                    .AddChild(Element.Slider("vol", 0, 100, 5).Size(220, 0)))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("ProgressBar:").Size(140, 0))
                    .AddChild(Element.ProgressBar(42, 100))))
            .AddChild(Element.ToolStrip()
                .AddChild(Element.Button("Submit text")
                    .OnClick((req: string) => req)
                    .OnResult("out-text"))
                .AddChild(Element.Button("Disabled").Enabled(false))
                .AddChild(Element.Button("Help").Tooltip("Hover me — that's a tooltip!")))
            .AddChild(Element.Pre("(click Submit)").Id("out-text").Size(0, 90))

        // ── Tab 2 — Choice widgets ───────────────────────────
        let choiceWidgets: Element = Element.Stack()
            .AddChild(Element.Heading("Selection"))
            .AddChild(Element.GroupBox("CheckBox / RadioButton (click the caption to toggle)")
                .AddChild(Element.CheckBoxLabel("agree", "I agree to the terms (CheckBox)"))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Priority:").Size(140, 0))
                    .AddChild(Element.RadioLabel("priority", "low",    "Low"))
                    .AddChild(Element.RadioLabel("priority", "normal", "Normal").Attr("checked", "checked"))
                    .AddChild(Element.RadioLabel("priority", "high",   "High"))))
            .AddChild(Element.GroupBox("ComboBox / ListBox / CheckedListBox")
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Theme (ComboBox):").Size(220, 0))
                    .AddChild(Element.Select("theme")
                        .AddChild(Element.Option("light", "Light"))
                        .AddChild(Element.Option("dark",  "Dark"))
                        .AddChild(Element.Option("auto",  "Auto"))))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Tags (ListBox multi-select):").Size(220, 0))
                    .AddChild(Element.ListBox("tags", 4)
                        .AddChild(Element.Option("a", "Alpha"))
                        .AddChild(Element.Option("b", "Beta"))
                        .AddChild(Element.Option("c", "Gamma"))
                        .AddChild(Element.Option("d", "Delta"))))
                .AddChild(Element.Label("Permissions (CheckedListBox):"))
                .AddChild(Element.CheckedListBox("perms")
                    .AddChild(Element.CheckedItem("perms", "read",  "Read"))
                    .AddChild(Element.CheckedItem("perms", "write", "Write"))
                    .AddChild(Element.CheckedItem("perms", "exec",  "Execute"))))
            .AddChild(Element.GroupBox("DateTimePicker / ColorDialog inline")
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Date:").Size(140, 0))
                    .AddChild(Element.DatePicker("when")))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Time:").Size(140, 0))
                    .AddChild(Element.TimePicker("hour")))
                .AddChild(Element.Row()
                    .AddChild(Element.Label("Color (ColorDialog):").Size(140, 0))
                    .AddChild(Element.ColorPicker("tint"))))
            .AddChild(Element.Button("Submit selection")
                .OnClick((req: string) => req)
                .OnResult("out-sel"))
            .AddChild(Element.Pre("(click Submit)").Id("out-sel").Size(0, 110))

        // ── Tab 3 — Layouts ──────────────────────────────────
        let layouts: Element = Element.Stack()
            .AddChild(Element.Heading("Layouts"))
            .AddChild(Element.GroupBox("Stack (vertical) / Row (horizontal) / Flow (wrap)")
                .AddChild(Element.Label("Stack — children flow vertically; Row — horizontally; Flow — wrap when overflowing."))
                .AddChild(Element.Flow("row")
                    .AddChild(Element.Button("flow A"))
                    .AddChild(Element.Button("flow B"))
                    .AddChild(Element.Button("flow C"))
                    .AddChild(Element.Button("flow D"))
                    .AddChild(Element.Button("flow E"))
                    .AddChild(Element.Button("flow F"))
                    .AddChild(Element.Button("flow G"))
                    .AddChild(Element.Button("flow H"))))
            .AddChild(Element.GroupBox("Grid (TableLayoutPanel)")
                .AddChild(Element.Grid(0, 3, 8)
                    .AddChild(Element.Button("1,1"))
                    .AddChild(Element.Button("1,2"))
                    .AddChild(Element.Button("1,3"))
                    .AddChild(Element.Button("2,1"))
                    .AddChild(Element.Button("2,2"))
                    .AddChild(Element.Button("2,3"))))
            .AddChild(Element.GroupBox("AbsoluteContainer + Position(x, y) — diagram-style placement")
                .AddChild(Element.AbsoluteContainer()
                    .Size(0, 140)
                    .AddChild(Element.Button("(20, 10)").Position(20, 10))
                    .AddChild(Element.Button("(160, 50)").Position(160, 50))
                    .AddChild(Element.Button("(40, 90)").Position(40, 90))))

        // ── Tab 4 — Tabular + embed + events ─────────────────
        let fileHeaders: List<string> = ["Name", "Size", "Modified"]
        let row1: List<string> = ["readme.md",  "2 KB",  "today"]
        let row2: List<string> = ["facade.am", "32 KB", "10:42"]
        let row3: List<string> = ["LICENSE",   "11 KB", "yesterday"]
        // The bodyId on ListView lets Page.AppendInner target the
        // tbody so the "Add row" button below grows the table
        // without re-rendering the whole page.
        let tabular: Element = Element.Stack()
            .AddChild(Element.Heading("Tables, links, embed, events"))
            .AddChild(Element.GroupBox("ListView (table) — partial-DOM patching")
                .AddChild(Element.ListView(fileHeaders, "files-body")
                    .AddChild(Element.ListViewRow(row1))
                    .AddChild(Element.ListViewRow(row2))
                    .AddChild(Element.ListViewRow(row3)))
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Add row")
                        .Attr("onclick", "window.amc_addrow('');"))
                    .AddChild(Element.Label("→  appends a new row via Page.AppendInner — no full re-render"))))
            .AddChild(Element.GroupBox("LinkLabel + PictureBox")
                .AddChild(Element.Row()
                    .AddChild(Element.Link("Open the Amalgame language site", "https://example.com"))
                    .AddChild(Element.Label("→  click — opens in your browser"))))
            .AddChild(Element.GroupBox("WebBrowser (iframe)")
                .AddChild(Element.Iframe("https://example.com").Size(0, 200)))
            .AddChild(Element.GroupBox("Event playground — focus / blur / type / Enter")
                .AddChild(Element.Input("playground")
                    .Attr("placeholder", "Try focusing, typing, blurring — every event fires")
                    .Tooltip("Each event echoes into the output below")
                    .OnFocus((req: string) => req)
                    .OnBlur((req: string) => req)
                    .OnChange((req: string) => req)
                    .OnKeyDown((req: string) => req)
                    .OnResult("out-events"))
                .AddChild(Element.Pre("(focus / type to see events)").Id("out-events").Size(0, 90)))

        // ── Tab 5 — Dialogs (MessageBox / Confirm / YesNoCancel) ──
        let dialogs: Element = Element.Stack()
            .AddChild(Element.Heading("Modal dialogs"))
            .AddChild(Element.GroupBox("Info / Warning / Error — single OK button")
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Info").Attr("onclick", "window.amc_dlg_info('');"))
                    .AddChild(Element.Button("Warning").Attr("onclick", "window.amc_dlg_warning('');"))
                    .AddChild(Element.Button("Error").Attr("onclick", "window.amc_dlg_error('');"))))
            .AddChild(Element.GroupBox("Confirm — OK / Cancel")
                .AddChild(Element.Button("Confirm quit").Attr("onclick", "window.amc_dlg_confirm('');")))
            .AddChild(Element.GroupBox("Yes / No / Cancel — save dialog")
                .AddChild(Element.Button("Save changes?").Attr("onclick", "window.amc_dlg_savecancel('');")))
            .AddChild(Element.Pre("(click a button — result echoes here)").Id("dlg-result").Size(0, 110))

        // ── Tab 6 — v0.0.7 (TreeView + File dialogs) ────────
        let tree: Element = Element.TreeView()
            .AddChild(Element.TreeNode("src").Attr("open", "open")
                .AddChild(Element.TreeNode("parser")
                    .AddChild(Element.TreeLeaf("ast.am"))
                    .AddChild(Element.TreeLeaf("parser.am")))
                .AddChild(Element.TreeNode("generator")
                    .AddChild(Element.TreeLeaf("c_gen.am")))
                .AddChild(Element.TreeLeaf("main.am")))
            .AddChild(Element.TreeNode("docs")
                .AddChild(Element.TreeLeaf("README.md"))
                .AddChild(Element.TreeLeaf("CHANGELOG.md")))
            .AddChild(Element.TreeLeaf("amalgame.toml"))

        let v07: Element = Element.Stack()
            .AddChild(Element.Heading("v0.0.7 — TreeView + file dialogs"))
            .AddChild(Element.GroupBox("TreeView (folders / files style)")
                .AddChild(tree))
            .AddChild(Element.GroupBox("File dialogs")
                .AddChild(Element.Row()
                    .AddChild(Element.Button("Open file").Attr("onclick", "window.amc_open_file('');"))
                    .AddChild(Element.Button("Save 'demo.txt'").Attr("onclick", "window.amc_save_file('');")))
                .AddChild(Element.Pre("(open a file or trigger a save — result echoes here)").Id("file-result").Size(0, 60)))

        // ── Compose the tabbed page ──────────────────────────
        // FillViewport() pins the body to 100vh — the TabControl
        // grows to fill remaining vertical space and scrolls
        // internally, so we don't get a window-level scrollbar
        // when one tab's content is taller than the viewport.
        let page: Page = Page.New()
            .SetTitle("amalgame-ui-web — gallery")
            .FillViewport()
            .SetBody(
                Element.Stack()
                    .AddChild(Element.Heading("amalgame-ui-web v0.0.5 — widget gallery"))
                    .AddChild(Element.Label("Switch tabs to browse the categories. The theme (light/dark) follows your OS — change it from your desktop settings and reopen this window."))
                    .AddChild(Element.TabControl("gal")
                        .AddChild(Element.Tab("gal", "inputs", "Text inputs", textInputs)
                            .Attr("checked", "checked"))
                        .AddChild(Element.Tab("gal", "choices", "Selection", choiceWidgets))
                        .AddChild(Element.Tab("gal", "layouts", "Layouts", layouts))
                        .AddChild(Element.Tab("gal", "tabular", "Tables + events", tabular))
                        .AddChild(Element.Tab("gal", "dialogs", "Dialogs", dialogs))
                        .AddChild(Element.Tab("gal", "v07", "v0.0.7", v07)))
                    .AddChild(Element.StatusStrip()
                        .AddChild(Element.Label("Ready"))
                        .AddChild(Element.Label("|"))
                        .AddChild(Element.Label("ui-web v0.0.5 gallery"))
                        .AddChild(Element.Label("|"))
                        .AddChild(Element.Label("OS-themed (light/dark auto)")))
            )

        // Bind the "Add row" handler BEFORE ApplyTo so the binding
        // is in the win's bind table when the page loads — webview
        // injects the shim during page load. The button itself
        // carries an onclick attribute calling window.amc_addrow,
        // so no Eval / DOMContentLoaded race involved.
        //
        // Each click captures the closure over `page` and `win`,
        // builds a fresh row, and Page.AppendInner injects it into
        // the ListView body without re-rendering the rest.
        var addCount: int = 0
        win.Bind("amc_addrow", (req: string) => {
            addCount = addCount + 1
            Console.WriteLine("[gallery] amc_addrow #" + String_FromInt(addCount))
            let r: List<string> = [
                "new-" + String_FromInt(addCount) + ".txt",
                "0 KB",
                "just now"
            ]
            page.AppendInner(win, "files-body", Element.ListViewRow(r))
            return "true"
        })

        // Dialog launchers — each button on tab 5 calls these.
        // The closure captures `win` so it can drive Dialog.Show.
        // Result handlers feed the choice back into #dlg-result via
        // Eval (a fully-AM way would be a sibling Bind that uses
        // page.PatchInner, but Eval keeps this snippet short).
        win.Bind("amc_dlg_info", (req: string) => {
            Dialog.Info(win, "Information", "All systems nominal.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Info result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_warning", (req: string) => {
            Dialog.Warning(win, "Warning", "This action cannot be undone.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Warning result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_error", (req: string) => {
            Dialog.Error(win, "Connection lost", "Failed to reach the server.\nPlease check your network.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Error result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_confirm", (req: string) => {
            Dialog.Confirm(win, "Quit?", "Unsaved changes will be lost.", (r: string) => {
                win.SetInnerHtml("dlg-result", "Confirm result: " + r)
                return ""
            })
            return "true"
        })
        win.Bind("amc_dlg_savecancel", (req: string) => {
            Dialog.YesNoCancel(win, "Save changes?", "Do you want to save before quitting?", (r: string) => {
                win.SetInnerHtml("dlg-result", "Save dialog result: " + r)
                return ""
            })
            return "true"
        })

        // v0.0.7 — file dialogs launchers.
        win.Bind("amc_open_file", (req: string) => {
            Dialog.OpenFile(win, "", (name: string) => {
                if (String_Length(name) > 0) {
                    win.SetInnerHtml("file-result", "Opened: " + name)
                } else {
                    win.SetInnerHtml("file-result", "(cancelled)")
                }
                return ""
            })
            return "true"
        })
        win.Bind("amc_save_file", (req: string) => {
            Dialog.SaveFile(win, "demo.txt", "Hello from amalgame-ui-web v0.0.7!\nGenerated " + String_FromInt(0) + " milliseconds ago.\n", "text/plain", (r: string) => {
                win.SetInnerHtml("file-result", "Save triggered: " + r)
                return ""
            })
            return "true"
        })

        page.ApplyTo(win)
        win.Run()
        win.Destroy()
    }
}
